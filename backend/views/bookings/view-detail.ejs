<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>

<style>
    .detail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .detail-card {
        background: white;
        border-radius: 1.5rem;
        padding: 2rem;
        border: 1px solid var(--border);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .detail-card h3 {
        margin-top: 0;
        margin-bottom: 1.5rem;
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--text-main);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
    }

    .detail-card h3 i {
        color: var(--primary);
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 0.875rem 0;
        border-bottom: 1px solid #f8f9fa;
        font-size: 0.9375rem;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        color: var(--text-muted);
        font-weight: 500;
    }

    .info-value {
        color: var(--text-main);
        font-weight: 600;
        text-align: right;
    }

    .status-badge {
        padding: 0.35rem 0.75rem;
        border-radius: 2rem;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .status-success {
        background: #ecfdf5;
        color: #059669;
    }

    .property-preview {
        display: flex;
        gap: 1rem;
        align-items: center;
        margin-bottom: 1rem;
    }

    .property-preview img {
        width: 80px;
        height: 60px;
        border-radius: 0.75rem;
        object-fit: cover;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 600;
        margin-bottom: 1.5rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--primary);
    }
</style>

<body>
    <div class="layout">
        <%- include('../partials/sidebar', { activePage: 'bookings' }) %>
        <main>
            <%- include('../partials/header', { pageTitle: 'Booking Details' }) %>

            <div class="content">
                <a href="/admin/bookings" class="back-link">
                    <i data-lucide="arrow-left"></i> Back to List
                </a>

                <div class="detail-grid">
                    <!-- Property & Owner Info -->
                    <div class="detail-card">
                        <h3><i data-lucide="home"></i> Property Information</h3>
                        <div class="property-preview">
                            <i data-lucide="image" style="width: 40px; height: 40px; opacity: 0.2;"></i>
                            <div>
                                <div style="font-weight: 700; color: var(--text-main);"><%= booking.property ? booking.property.propertyName : 'Property #' + booking.propertyId %></div>
                                <div style="font-size: 0.8125rem; color: var(--text-muted);">
                                    <%= booking.city %>, <%= booking.country %>
                                </div>
                            </div>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Property ID</span>
                            <span class="info-value">#<%= booking.propertyId %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Owner ID</span>
                            <span class="info-value">#<%= booking.propertyOwner || 'N/A' %></span>
                        </div>
                    </div>

                    <!-- Customer Info -->
                    <div class="detail-card">
                        <h3><i data-lucide="user"></i> Customer Details</h3>
                        <div class="info-row">
                            <span class="info-label">Name</span>
                            <span class="info-value"><%= booking.firstName %> <%= booking.lastName %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Email</span>
                            <span class="info-value"><%= booking.email %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Mobile</span>
                            <span class="info-value"><%= booking.mobile %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Address</span>
                            <span class="info-value"><%= booking.street %>, <%= booking.city %>, <%= booking.zip %></span>
                        </div>
                    </div>

                    <!-- Booking & Payment Details -->
                    <div class="detail-card">
                        <h3><i data-lucide="credit-card"></i> Booking Summary</h3>
                        <div class="info-row">
                            <span class="info-label">Booking Dates</span>
                            <span class="info-value" style="color: var(--primary);"><%= booking.bookingDates %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Amount Paid</span>
                            <span class="info-value" style="font-size: 1.125rem; color: var(--text-main);">$<%= booking.amount %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Status</span>
                            <span class="info-value">
                                <span class="status-badge <%= booking.status === 'success' ? 'status-success' : '' %>">
                                    <%= booking.status %>
                                </span>
                            </span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Transaction ID</span>
                            <span class="info-value" style="font-family: monospace; font-size: 0.8125rem;"><%= booking.transactionId || 'Internal' %></span>
                        </div>
                    </div>

                    <!-- Additional Info -->
                    <div class="detail-card" style="grid-column: 1 / -1;">
                        <h3><i data-lucide="info"></i> Additional Information</h3>
                        <div class="info-row" style="flex-direction: column; gap: 0.5rem; align-items: flex-start;">
                            <span class="info-label">Customer Message</span>
                            <div style="background: #fcfcfd; padding: 1.25rem; border-radius: 1rem; width: 100%; border: 1px solid var(--border);">
                                <%= booking.message || 'No message provided.' %>
                            </div>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Order Date</span>
                            <span class="info-value"><%= new Date(booking.createdAt).toLocaleString() %></span>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.lucide) lucide.createIcons();
        });
    </script>
</body>
</html>
