<!DOCTYPE html>
<html lang="en">
<%- include('../../partials/head') %>

    <style>
        .data-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-bottom: 2rem;
        }

        .data-table th {
            text-align: left;
            padding: 1.25rem 1.5rem;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.875rem;
            border-bottom: 1px solid var(--border);
            background-color: #fafbfc;
        }

        .data-table td {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border);
            font-size: 0.9375rem;
            vertical-align: middle;
        }

        .search-box {
            position: relative;
            display: flex;
            align-items: center;
        }

        .search-box i {
            position: absolute;
            left: 1.25rem;
            width: 18px;
            height: 18px;
            color: var(--text-muted);
            pointer-events: none;
            transition: color 0.2s;
        }

        .search-box input {
            padding: 0.875rem 1.25rem 0.875rem 3.25rem;
            border-radius: 1rem;
            border: 1.5px solid var(--border);
            background: white;
            min-width: 350px;
            font-size: 0.9375rem;
            outline: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            color: var(--text-main);
        }

        .search-box input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

        .pagination-footer {
            margin-top: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .pagination-info {
            font-size: 0.875rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .pagination-info span {
            color: var(--text-main);
            font-weight: 600;
        }

        .pagination-controls {
            display: flex;
            gap: 0.5rem;
        }

        .page-btn {
            min-width: 40px;
            height: 40px;
            border-radius: 0.75rem;
            border: 1.5px solid var(--border);
            background: white;
            color: var(--text-main);
            font-size: 0.875rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
        }

        .page-btn:hover:not(:disabled) {
            border-color: var(--primary);
            color: var(--primary);
        }

        .page-btn.active {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
        }

        .page-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .action-btns {
            display: flex;
            gap: 0.5rem;
        }

        .action-btn {
            width: 32px;
            height: 32px;
            border-radius: 0.5rem;
            border: 1px solid var(--border);
            background: white;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
        }

        .action-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
            background-color: #f8f9ff;
        }

        .action-btn.btn-delete:hover {
            border-color: #ef4444;
            color: #ef4444;
            background-color: #fef2f2;
        }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            z-index: 1000;
            backdrop-filter: blur(4px);
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: white;
            width: 100%;
            max-width: 600px;
            border-radius: 1.5rem;
            padding: 2.5rem;
            position: relative;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .modal-header {
            margin-bottom: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h3 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 700;
        }

        .close-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            padding: 0.5rem;
            border-radius: 0.5rem;
            transition: all 0.2s;
        }

        .close-btn:hover {
            background: #f1f5f9;
            color: var(--text-main);
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.25rem;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-group.full-width {
            grid-column: span 2;
        }

        .form-group label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }

        .form-group input {
            width: 100%;
            padding: 0.75rem 1rem;
            border-radius: 0.75rem;
            border: 1.5px solid var(--border);
            font-size: 0.9375rem;
            outline: none;
            transition: all 0.2s;
        }

        .form-group input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

        .modal-footer {
            margin-top: 2rem;
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
        }
    </style>

    <body>
        <div class="layout">
            <%- include('../../partials/sidebar', { activePage: 'settings-employees' }) %>
                <main>
                    <%- include('../../partials/header', { pageTitle: 'Employee Management' }) %>

                        <div class="card">
                            <div class="controls-row"
                                style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; gap: 1rem; flex-wrap: wrap;">
                                <div style="flex: 1; min-width: 250px;">
                                    <h3 style="margin: 0">Staff Members</h3>
                                    <p style="color: var(--text-muted); font-size: 0.875rem">Manage employee accounts and permissions</p>
                                </div>

                                <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                                    <div class="search-box">
                                        <i data-lucide="search"></i>
                                        <input type="text" id="table-search" placeholder="Search by name or email..."
                                            value="<%= searchQuery %>">
                                    </div>
                                    <button class="btn-primary" onclick="openAddModal()" style="display: flex; align-items: center; gap: 0.5rem;">
                                        <i data-lucide="user-plus" size="18"></i> Add Employee
                                    </button>
                                </div>
                            </div>

                            <div class="table-container">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>#ID</th>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody id="employee-table-body">
                                        <%- include('partials/table-rows') %>
                                    </tbody>
                                </table>
                            </div>

                            <div class="pagination-footer">
                                <div class="pagination-info">
                                    Showing <span id="start-count">0</span> to <span id="end-count">0</span> of <span
                                        id="total-count">
                                        <%= totalCount %>
                                    </span> entries
                                </div>
                                <div class="pagination-controls" id="pagination-controls"></div>
                            </div>
                        </div>
                </main>
        </div>

        <!-- Add/Edit Employee Modal -->
        <div id="employee-modal" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 id="modal-title">Add New Employee</h3>
                    <button class="close-btn" onclick="closeModal('employee-modal')">
                        <i data-lucide="x"></i>
                    </button>
                </div>
                <form id="employee-form" onsubmit="handleEmployeeSubmit(event)">
                    <input type="hidden" id="edit-id" name="id">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>First Name</label>
                            <input type="text" name="firstname" required placeholder="John">
                        </div>
                        <div class="form-group">
                            <label>Last Name</label>
                            <input type="text" name="lastname" required placeholder="Doe">
                        </div>
                        <div class="form-group full-width">
                            <label>Email Address</label>
                            <input type="email" name="email" required placeholder="john@example.com">
                        </div>
                        <div class="form-group full-width">
                            <label>Contact Number</label>
                            <input type="text" name="contact_number" required placeholder="+1 234 567 890">
                        </div>

                        <!-- Password Section (Add mode only) -->
                        <div class="form-group full-width" id="password-section">
                            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; padding: 0.875rem 1rem; background: #f8f9ff; border-radius: 0.75rem; border: 1.5px solid rgba(79,70,229,0.15); cursor: pointer;" onclick="document.getElementById('sys-gen-pwd').click()">
                                <input type="checkbox" id="sys-gen-pwd" name="system_generated_password" checked
                                    style="width: 18px; height: 18px; accent-color: var(--primary); cursor: pointer;"
                                    onchange="togglePasswordFields()">
                                <div>
                                    <label for="sys-gen-pwd" style="margin: 0; cursor: pointer; font-weight: 600; color: var(--text-main); font-size: 0.9rem;">System Generated Password</label>
                                    <p style="margin: 0.2rem 0 0; font-size: 0.78rem; color: var(--text-muted);">A random password will be generated and sent to the employee's email</p>
                                </div>
                            </div>

                            <div id="manual-password-fields" style="display: none;">
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;">
                                    <div class="form-group" style="margin-bottom: 0;">
                                        <label>New Password</label>
                                        <input type="password" name="password" id="manual-password" minlength="6" placeholder="At least 6 characters">
                                    </div>
                                    <div class="form-group" style="margin-bottom: 0;">
                                        <label>Confirm Password</label>
                                        <input type="password" name="confirm_password" id="confirm-password" minlength="6" placeholder="Re-enter password">
                                    </div>
                                </div>
                                <p id="password-mismatch" style="display: none; color: #ef4444; font-size: 0.78rem; margin-top: 0.5rem; font-weight: 500;">
                                    <i data-lucide="alert-circle" style="width:14px; height:14px; display:inline-block; vertical-align:middle; margin-right:4px;"></i>
                                    Passwords do not match
                                </p>
                            </div>
                        </div> <!-- password-section closed -->

                        <!-- Status (Edit mode only) -->
                        <div class="form-group full-width" id="status-group" style="display: none;">
                            <label>Status</label>
                            <div style="display: flex; gap: 1rem;">
                                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500; background: #ecfdf5; color: #10b981; padding: 0.5rem 1rem; border-radius: 0.75rem; border: 1.5px solid rgba(16,185,129,0.1);">
                                    <input type="radio" name="status" value="0" checked style="accent-color: #10b981; width: 16px; height: 16px;"> Active
                                </label>
                                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500; background: #fef2f2; color: #ef4444; padding: 0.5rem 1rem; border-radius: 0.75rem; border: 1.5px solid rgba(239,68,68,0.1);">
                                    <input type="radio" name="status" value="1" style="accent-color: #ef4444; width: 16px; height: 16px;"> Inactive
                                </label>
                            </div>
                        </div>
                    </div> <!-- form-grid closed -->
                    <div class="modal-footer">
                        <button type="button" class="btn-secondary" onclick="closeModal('employee-modal')" style="background: #f1f5f9; border: none; padding: 0.75rem 1.5rem; border-radius: 0.75rem; cursor: pointer; color: var(--text-muted); font-weight: 600;">Cancel</button>
                        <button type="submit" class="btn-primary" id="save-btn">Save Employee</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Change Password Modal -->
        <div id="password-modal" class="modal">
            <div class="modal-content" style="max-width: 400px;">
                <div class="modal-header">
                    <h3>Change Password</h3>
                    <button class="close-btn" onclick="closeModal('password-modal')">
                        <i data-lucide="x"></i>
                    </button>
                </div>
                <form id="password-form" onsubmit="handlePasswordSubmit(event)">
                    <input type="hidden" id="password-user-id" name="id">
                    <div class="form-group">
                        <label>New Password</label>
                        <input type="password" id="new-password" name="password" required minlength="6" placeholder="Enter new password">
                    </div>
                    <div class="form-group">
                        <label>Confirm Password</label>
                        <input type="password" id="confirm-new-password" name="confirm_password" required minlength="6" placeholder="Re-enter new password">
                    </div>
                    <p id="password-mismatch-modal" style="display: none; color: #ef4444; font-size: 0.78rem; margin-top: 0.5rem; font-weight: 500;">
                        <i data-lucide="alert-circle" style="width:14px; height:14px; display:inline-block; vertical-align:middle; margin-right:4px;"></i>
                        Passwords do not match
                    </p>
                    <div class="modal-footer">
                        <button type="button" class="btn-secondary" onclick="closeModal('password-modal')" style="background: #f1f5f9; border: none; padding: 0.75rem 1.5rem; border-radius: 0.75rem; cursor: pointer; color: var(--text-muted); font-weight: 600;">Cancel</button>
                        <button type="submit" class="btn-primary">Update Password</button>
                    </div>
                </form>
            </div>
        </div>

        <div id="pagination-config" 
             data-current-page="<%= currentPage %>" 
             data-total-pages="<%= totalPages %>" 
             data-total-count="<%= totalCount %>" 
             style="display: none;"></div>

        <script>
            function getConfig() {
                const el = document.getElementById('pagination-config');
                return el ? el.dataset : {};
            }

            window.currentPage = parseInt(getConfig().currentPage) || 1;

            function closeModal(id) {
                const modal = document.getElementById(id);
                if (modal) modal.classList.remove('active');
            }

            function togglePasswordFields() {
                const isChecked = document.getElementById('sys-gen-pwd').checked;
                const manualFields = document.getElementById('manual-password-fields');
                const pwd = document.getElementById('manual-password');
                const confirmPwd = document.getElementById('confirm-password');

                if (isChecked) {
                    if (manualFields) manualFields.style.display = 'none';
                    if (pwd) pwd.required = false;
                    if (confirmPwd) confirmPwd.required = false;
                } else {
                    if (manualFields) manualFields.style.display = 'block';
                    if (pwd) pwd.required = true;
                    if (confirmPwd) confirmPwd.required = true;
                }
                const err = document.getElementById('password-mismatch');
                if (err) err.style.display = 'none';
                if (window.lucide) lucide.createIcons();
            }

            function openAddModal() {
                document.getElementById('modal-title').textContent = 'Add New Employee';
                document.getElementById('edit-id').value = '';
                document.getElementById('employee-form').reset();
                document.getElementById('password-section').style.display = 'block';
                document.getElementById('status-group').style.display = 'none';
                document.getElementById('sys-gen-pwd').checked = true;
                togglePasswordFields();
                document.getElementById('employee-modal').classList.add('active');
                if (window.lucide) lucide.createIcons();
            }

            function openEditModal(userData) {
                let user;
                try {
                    user = typeof userData === 'string' ? JSON.parse(userData) : userData;
                } catch (e) {
                    console.error('Failed to parse user data:', e);
                    return;
                }
                if (!user) return;
                document.getElementById('modal-title').textContent = 'Edit Employee';
                document.getElementById('edit-id').value = user.id;
                document.getElementById('password-section').style.display = 'none';
                document.getElementById('status-group').style.display = 'block';
                
                const form = document.getElementById('employee-form');
                form.elements['firstname'].value = user.firstname;
                form.elements['lastname'].value = user.lastname;
                form.elements['email'].value = user.email;
                form.elements['contact_number'].value = user.contact_number;
                form.elements['status'].value = user.status;
                
                // Disable password validation for edit mode
                const pwd = document.getElementById('manual-password');
                const confirmPwd = document.getElementById('confirm-password');
                if (pwd) pwd.required = false;
                if (confirmPwd) confirmPwd.required = false;

                document.getElementById('employee-modal').classList.add('active');
                if (window.lucide) lucide.createIcons();
            }

            function openPasswordModal(id) {
                console.log('Opening password modal for employee ID:', id);
                
                const idInput = document.getElementById('password-user-id');
                const form = document.getElementById('password-form');
                const modal = document.getElementById('password-modal');
                const err = document.getElementById('password-mismatch-modal');

                if (idInput) idInput.value = id;
                if (form) form.reset();
                if (err) err.style.display = 'none';
                
                if (modal) {
                    modal.classList.add('active');
                } else {
                    console.error('Password modal element not found!');
                }

                if (window.lucide && typeof lucide.createIcons === 'function') {
                    lucide.createIcons();
                }
            }

            async function handleEmployeeSubmit(e) {
                e.preventDefault();
                const form = e.target;
                const id = document.getElementById('edit-id').value;
                const isAddMode = !id;

                // Build data
                const data = {
                    firstname: form.elements['firstname'].value,
                    lastname: form.elements['lastname'].value,
                    email: form.elements['email'].value,
                    contact_number: form.elements['contact_number'].value,
                    status: form.elements['status'] ? form.elements['status'].value : 0,
                };

                if (isAddMode) {
                    const sysGen = document.getElementById('sys-gen-pwd').checked;
                    data.system_generated_password = sysGen;

                    if (!sysGen) {
                        const pwd = document.getElementById('manual-password').value;
                        const confirmPwd = document.getElementById('confirm-password').value;

                        if (pwd !== confirmPwd) {
                            document.getElementById('password-mismatch').style.display = 'block';
                            if (window.lucide) lucide.createIcons();
                            return;
                        }
                        data.password = pwd;
                        data.confirm_password = confirmPwd;
                    }
                }

                const url = id 
                    ? `/api/admin/settings/employees/${id}/update`
                    : '/api/admin/settings/employees/add';
                
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    
                    if (response.ok) {
                        const result = await response.json();
                        closeModal('employee-modal');
                        updateTable(window.currentPage, document.getElementById('table-search').value);

                        if (isAddMode && result.generatedPassword) {
                            alert(`Employee created successfully!\n\nCredentials (sent to ${data.email}):\nUsername: ${data.email}\nPassword: ${result.generatedPassword}`);
                        } else if (isAddMode) {
                            alert('Employee created successfully!');
                        }
                    } else {
                        const err = await response.json().catch(() => null);
                        alert(err?.message || 'Error saving employee. Email might already exist.');
                    }
                } catch (error) {
                    console.error('Submit failed:', error);
                }
            }

            async function handlePasswordSubmit(e) {
                e.preventDefault();
                const id = document.getElementById('password-user-id').value;
                const password = document.getElementById('new-password').value;
                const confirmPassword = document.getElementById('confirm-new-password').value;
                
                if (password !== confirmPassword) {
                    document.getElementById('password-mismatch-modal').style.display = 'block';
                    if (window.lucide) lucide.createIcons();
                    return;
                }

                try {
                    const response = await fetch(`/api/admin/settings/employees/${id}/change-password`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ password })
                    });
                    
                    if (response.ok) {
                        closeModal('password-modal');
                        alert('Password updated successfully!');
                    }
                } catch (error) {
                    console.error('Password update failed:', error);
                }
            }

            async function toggleEmployeeStatus(id) {
                try {
                    const response = await fetch(`/api/admin/settings/employees/${id}/toggle-status`, { method: 'POST' });
                    if (response.ok) {
                        updateTable(window.currentPage, document.getElementById('table-search').value);
                    }
                } catch (error) {
                    console.error('Toggle status failed:', error);
                }
            }

            async function deleteEmployee(id) {
                if (confirm('Are you sure you want to delete this employee? This action is a soft-delete.')) {
                    try {
                        const response = await fetch(`/api/admin/settings/employees/${id}/delete`, { method: 'POST' });
                        if (response.ok) {
                            updateTable(window.currentPage, document.getElementById('table-search').value);
                        }
                    } catch (error) {
                        console.error('Delete failed:', error);
                    }
                }
            }

            async function updateTable(page = 1, search = '') {
                const tbody = document.getElementById('employee-table-body');
                const response = await fetch(`/api/admin/settings/employees?page=${page}&search=${search}&ajax=true`);
                const html = await response.text();
                tbody.innerHTML = html;

                const paginationData = document.getElementById('pagination-data');
                if (paginationData) {
                    window.currentPage = parseInt(paginationData.dataset.currentPage);
                    renderPagination(window.currentPage, parseInt(paginationData.dataset.totalPages));
                    updateInfo(window.currentPage, parseInt(paginationData.dataset.totalCount));
                }
                if (window.lucide) lucide.createIcons();
            }

            function renderPagination(current, total) {
                const controls = document.getElementById('pagination-controls');
                if (!controls) return;
                let html = `<button class="page-btn" ${current === 1 ? 'disabled' : ''} onclick="updateTable(${current - 1}, document.getElementById('table-search').value)">Previous</button>`;
                for (let i = 1; i <= total; i++) {
                    if (i === 1 || i === total || (i >= current - 1 && i <= current + 1)) {
                        html += `<button class="page-btn ${i === current ? 'active' : ''}" onclick="updateTable(${i}, document.getElementById('table-search').value)">${i}</button>`;
                    } else if (i === current - 2 || i === current + 2) {
                        html += `<span style="padding: 0.5rem">...</span>`;
                    }
                }
                html += `<button class="page-btn" ${current === total || total === 0 ? 'disabled' : ''} onclick="updateTable(${current + 1}, document.getElementById('table-search').value)">Next</button>`;
                controls.innerHTML = html;
            }

            function updateInfo(current, total) {
                const pageSize = 10;
                const start = total === 0 ? 0 : (current - 1) * pageSize + 1;
                const end = Math.min(current * pageSize, total);
                if (document.getElementById('start-count')) document.getElementById('start-count').textContent = start;
                if (document.getElementById('end-count')) document.getElementById('end-count').textContent = end;
                if (document.getElementById('total-count')) document.getElementById('total-count').textContent = total;
            }

            document.addEventListener('DOMContentLoaded', () => {
                const cfg = getConfig();
                if (window.lucide) lucide.createIcons();

                let timeout;
                document.getElementById('table-search').addEventListener('input', (e) => {
                    clearTimeout(timeout);
                    timeout = setTimeout(() => updateTable(1, e.target.value), 400);
                });

                // Initial pagination
                const pageCfg = getConfig();
                renderPagination(window.currentPage, parseInt(pageCfg.totalPages) || 1);
                updateInfo(window.currentPage, parseInt(pageCfg.totalCount) || 0);
            });
        </script>
    </body>

</html>
