        <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
        <script>
            // Initialize Quill
            const quill = new Quill('#editor', {
                theme: 'snow',
                modules: {
                    toolbar: [
                        ['bold', 'italic', 'underline'],
                        [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                        [{ 'align': [] }],
                        ['clean']
                    ]
                }
            });

            // Sync Quill content to hidden input
            quill.on('text-change', () => {
                document.getElementById('propertyDescription').value = quill.root.innerHTML;
            });

            // Initialize second Quill for Amenities
            const amenityQuill = new Quill('#amenity-editor', {
                theme: 'snow',
                modules: {
                    toolbar: [
                        ['bold', 'italic', 'underline'],
                        [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                        ['clean']
                    ]
                }
            });

            amenityQuill.on('text-change', () => {
                document.getElementById('additionalInfo').value = amenityQuill.root.innerHTML;
            });

            // Tab Navigation
            function nextTab(tabNumber) {
                // In a real scenario, you'd validate current tab first
                if (tabNumber === 6) renderPropertiesCalendar(); // Initialize calendar when entering tab 6
                switchTab(tabNumber);
            }

            // Availability Calendar Logic
            let calendarYear = new Date().getFullYear();
            let calendarMonth = new Date().getMonth();
            let blockedDates = {}; // Format: { "YYYY-MM-DD": "booked|am|pm" }

            function renderPropertiesCalendar() {
                const container = document.getElementById('calendar-render-area');
                container.innerHTML = '';

                // Render 4 months starting from current calendar state to match screenshot look
                for (let i = 0; i < 4; i++) {
                    let m = calendarMonth + i;
                    let y = calendarYear;
                    if (m > 11) {
                        m -= 12;
                        y++;
                    }
                    container.appendChild(generateMonthElement(y, m));
                }
                lucide.createIcons();
            }

            function generateMonthElement(year, month) {
                const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
                const div = document.createElement('div');
                div.className = 'calendar-month';

                let html = `
                <div class="month-header">${monthNames[month]} ${year}</div>
                <div class="weekdays-grid">
                    <div>M</div><div>T</div><div>W</div><div>T</div><div>F</div><div>S</div><div>S</div>
                </div>
                <div class="days-grid">
            `;

                const firstDay = new Date(year, month, 1).getDay(); // 0 is Sunday
                const daysInMonth = new Date(year, month + 1, 0).getDate();

                // Adjust for Monday start (0=Sun, 1=Mon...6=Sat)
                let startingPadding = firstDay === 0 ? 6 : firstDay - 1;

                // Padding from prev month
                const prevMonthDays = new Date(year, month, 0).getDate();
                for (let i = startingPadding - 1; i >= 0; i--) {
                    html += `<div class="day-cell other-month">${prevMonthDays - i}</div>`;
                }

                // Actual days
                const today = new Date();
                for (let d = 1; d <= daysInMonth; d++) {
                    const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
                    const status = blockedDates[dateStr] || '';
                    const isToday = today.getFullYear() === year && today.getMonth() === month && today.getDate() === d;

                    let statusClass = '';
                    if (status === 'booked') statusClass = 'status-booked';
                    else if (status === 'am') statusClass = 'status-booked-am';
                    else if (status === 'pm') statusClass = 'status-booked-pm';

                    html += `
                    <div class="day-cell ${isToday ? 'today' : ''} ${statusClass}" 
                         data-date="${dateStr}" 
                         onclick="handleDateClick(this)">
                        ${d}
                    </div>
                `;
                }

                html += `</div>`;
                div.innerHTML = html;
                return div;
            }

            function handleDateClick(el) {
                const dateStr = el.dataset.date;
                if (!dateStr) return;

                const method = document.querySelector('.click-method-select').value;
                let currentStatus = blockedDates[dateStr] || 'available';

                if (method === 'cycle') {
                    if (currentStatus === 'available') currentStatus = 'booked';
                    else if (currentStatus === 'booked') currentStatus = 'am';
                    else if (currentStatus === 'am') currentStatus = 'pm';
                    else currentStatus = 'available';
                } else {
                    currentStatus = method === 'available' ? 'available' : method;
                }

                // Update state
                if (currentStatus === 'available') {
                    delete blockedDates[dateStr];
                } else {
                    blockedDates[dateStr] = currentStatus;
                }

                // Update UI
                el.classList.remove('status-booked', 'status-booked-am', 'status-booked-pm');
                if (currentStatus === 'booked') el.classList.add('status-booked');
                else if (currentStatus === 'am') el.classList.add('status-booked-am');
                else if (currentStatus === 'pm') el.classList.add('status-booked-pm');

                // Sync hidden input
                document.getElementById('calendarBlockedDatesInput').value = JSON.stringify(blockedDates);
            }

            function nextMonth() { calendarMonth++; if (calendarMonth > 11) { calendarMonth = 0; calendarYear++; } renderPropertiesCalendar(); }
            function prevMonth() { calendarMonth--; if (calendarMonth < 0) { calendarMonth = 11; calendarYear--; } renderPropertiesCalendar(); }
            function nextYear() { calendarYear++; renderPropertiesCalendar(); }
            function prevYear() { calendarYear--; renderPropertiesCalendar(); }

            function prevTab(tabNumber) {
                switchTab(tabNumber);
            }

            function switchTab(n) {
                document.querySelectorAll('.tab-item').forEach(item => {
                    item.classList.remove('active');
                    if (item.dataset.tab == n) item.classList.add('active');
                });
                document.querySelectorAll('.tab-content').forEach(content => {
                    content.classList.remove('active');
                });
                document.getElementById(`tab-${n}`).classList.add('active');

                // Update progress bar
                const percent = (n / 6) * 100;
                document.getElementById('form-progress').style.width = `${percent}%`;

                window.scrollTo(0, 0);
            }

            // Seasonal Rates Logic Refined
            let seasonalRates = [];
            let editingRateIndex = null;

            function saveSeasonalRate() {
                const seasonName = document.getElementById('rate_season_name').value;
                const startDate = document.getElementById('rate_start_date').value;
                const endDate = document.getElementById('rate_end_date').value;
                const minStay = document.getElementById('rate_min_stay').value;
                const weekendNight = document.getElementById('rate_weekend_night').value;
                const nightly = document.getElementById('rate_nightly').value;
                const weekly = document.getElementById('rate_weekly').value;
                const monthly = document.getElementById('rate_monthly').value;

                if (!seasonName || !startDate || !endDate) {
                    alert('Please fill in at least the Season Name, Start Date, and End Date.');
                    return;
                }

                const rateData = {
                    seasonName,
                    startDate,
                    endDate,
                    minStay,
                    weekendNight,
                    nightly,
                    weekly,
                    monthly
                };

                if (editingRateIndex !== null) {
                    seasonalRates[editingRateIndex] = rateData;
                    editingRateIndex = null;
                    document.querySelector('.btn-rate-save').textContent = 'Save';
                } else {
                    seasonalRates.push(rateData);
                }

                renderRatesTable();
                clearRateForm();
            }

            function editSeasonalRate(index) {
                const rate = seasonalRates[index];
                document.getElementById('rate_season_name').value = rate.seasonName;
                document.getElementById('rate_start_date').value = rate.startDate;
                document.getElementById('rate_end_date').value = rate.endDate;
                document.getElementById('rate_min_stay').value = rate.minStay;
                document.getElementById('rate_weekend_night').value = rate.weekendNight;
                document.getElementById('rate_nightly').value = rate.nightly;
                document.getElementById('rate_weekly').value = rate.weekly;
                document.getElementById('rate_monthly').value = rate.monthly;

                editingRateIndex = index;
                document.querySelector('.btn-rate-save').textContent = 'Update';

                // Scroll to form
                document.querySelector('.rates-form-container').scrollIntoView({ behavior: 'smooth' });
            }

            async function deleteSeasonalRate(index) {
                const confirmed = await openDeleteModal('Delete Rate', 'Are you sure you want to delete this rate?');
                if (confirmed) {
                    seasonalRates.splice(index, 1);
                    renderRatesTable();
                    if (editingRateIndex === index) clearRateForm();
                }
            }

            function renderRatesTable() {
                const tbody = document.getElementById('rates-table-body');
                tbody.innerHTML = '';

                seasonalRates.forEach((rate, index) => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                    <td>${rate.seasonName}</td>
                    <td>${rate.startDate}</td>
                    <td>${rate.endDate}</td>
                    <td>${rate.minStay || '-'}</td>
                    <td>${rate.nightly || '-'}</td>
                    <td>${rate.weekly || '-'}</td>
                    <td>${rate.weekendNight || '-'}</td>
                    <td>${rate.monthly || '-'}</td>
                    <td>
                        <button type="button" class="rates-action-btn btn-edit-rate" onclick="editSeasonalRate(${index})">Edit</button>
                        <button type="button" class="rates-action-btn btn-delete-rate" onclick="deleteSeasonalRate(${index})">Delete</button>
                    </td>
                `;
                    tbody.appendChild(row);
                });

                // Sync with hidden input
                document.getElementById('seasonalRatesInput').value = JSON.stringify(seasonalRates);
            }

            function clearRateForm() {
                document.getElementById('rate_season_name').value = '';
                document.getElementById('rate_start_date').value = '';
                document.getElementById('rate_end_date').value = '';
                document.getElementById('rate_min_stay').value = '';
                document.getElementById('rate_weekend_night').value = '';
                document.getElementById('rate_nightly').value = '';
                document.getElementById('rate_weekly').value = '';
                document.getElementById('rate_monthly').value = '';

                editingRateIndex = null;
                document.querySelector('.btn-rate-save').textContent = 'Save';
            }

            // Initialize Payment Terms Quill
            const paymentQuill = new Quill('#payment-editor', {
                theme: 'snow',
                modules: {
                    toolbar: [
                        ['bold', 'italic', 'underline'],
                        [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                        ['clean']
                    ]
                }
            });

            paymentQuill.on('text-change', () => {
                document.getElementById('paymentTermsInput').value = paymentQuill.root.innerHTML;
            });

            // Add click listeners to tabs
            document.querySelectorAll('.tab-item').forEach(item => {
                item.addEventListener('click', () => {
                    switchTab(item.dataset.tab);
                });
            });

            // Dynamic Locations (Tab 1)
            async function handleCountryChange() {
                const countryId = document.getElementById('country-select').value;
                const stateSelect = document.getElementById('state-select');
                const citySelect = document.getElementById('city-select');

                stateSelect.innerHTML = '<option value="">Select State</option>';
                citySelect.innerHTML = '<option value="">Select City</option>';

                if (countryId) {
                    const response = await fetch(`/api/admin/settings/data/states?countryId=${countryId}`);
                    const states = await response.json();
                    states.forEach(s => {
                        const option = document.createElement('option');
                        option.value = s.id;
                        option.dataset.name = s.name;
                        option.textContent = s.name;
                        stateSelect.appendChild(option);
                    });
                }
            }

            async function handleStateChange() {
                const stateId = document.getElementById('state-select').value;
                const citySelect = document.getElementById('city-select');

                citySelect.innerHTML = '<option value="">Select City</option>';

                if (stateId) {
                    const response = await fetch(`/api/admin/settings/data/cities?stateId=${stateId}`);
                    const cities = await response.json();
                    cities.forEach(c => {
                        const option = document.createElement('option');
                        option.value = c.id;
                        option.dataset.name = c.name;
                        option.textContent = c.name;
                        citySelect.appendChild(option);
                    });
                }
            }

            // Dynamic Locations (Tab 2: Contact)
            async function handleContactCountryChange() {
                const countryId = document.getElementById('contact-country-select').value;
                const stateSelect = document.getElementById('contact-state-select');
                const citySelect = document.getElementById('contact-city-select');

                stateSelect.innerHTML = '<option value="">Select State</option>';
                citySelect.innerHTML = '<option value="">Select City</option>';

                if (countryId) {
                    const response = await fetch(`/api/admin/settings/data/states?countryId=${countryId}`);
                    const states = await response.json();
                    states.forEach(s => {
                        const option = document.createElement('option');
                        option.value = s.id;
                        option.dataset.name = s.name;
                        option.textContent = s.name;
                        stateSelect.appendChild(option);
                    });
                }
            }

            async function handleContactStateChange() {
                const stateId = document.getElementById('contact-state-select').value;
                const citySelect = document.getElementById('contact-city-select');

                citySelect.innerHTML = '<option value="">Select City</option>';

                if (stateId) {
                    const response = await fetch(`/api/admin/settings/data/cities?stateId=${stateId}`);
                    const cities = await response.json();
                    cities.forEach(c => {
                        const option = document.createElement('option');
                        option.value = c.id;
                        option.dataset.name = c.name;
                        option.textContent = c.name;
                        citySelect.appendChild(option);
                    });
                }
            }

            // Multiple Photos Management
            let propertyPhotos = []; // Stores { file, isMain, id }

            const photoInput = document.getElementById('photo-input');
            const photoUploadZone = document.getElementById('photo-upload-zone');
            const photoPreviewGrid = document.getElementById('photo-preview-grid');

            photoInput.addEventListener('change', (e) => {
                handlePhotoUpload(e.target.files);
                photoInput.value = ''; // Reset for same file re-selection
            });

            photoUploadZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                photoUploadZone.classList.add('drag-over');
            });

            photoUploadZone.addEventListener('dragleave', () => {
                photoUploadZone.classList.remove('drag-over');
            });

            photoUploadZone.addEventListener('drop', (e) => {
                e.preventDefault();
                photoUploadZone.classList.remove('drag-over');
                handlePhotoUpload(e.dataTransfer.files);
            });

            function handlePhotoUpload(files) {
                Array.from(files).forEach(file => {
                    if (!file.type.startsWith('image/')) return;

                    const photoObj = {
                        file: file,
                        isMain: propertyPhotos.length === 0, // First photo is main by default
                        id: Math.random().toString(36).substr(2, 9)
                    };
                    propertyPhotos.push(photoObj);
                });
                renderPhotoPreviews();
            }

            function renderPhotoPreviews() {
                photoPreviewGrid.innerHTML = '';

                propertyPhotos.forEach((photo, index) => {
                    const url = URL.createObjectURL(photo.file);
                    const card = document.createElement('div');
                    card.className = 'photo-card';
                    card.innerHTML = `
                    <img src="${url}" alt="Preview">
                    <div class="photo-actions">
                        <button type="button" class="action-icon btn-main-photo ${photo.isMain ? 'active' : ''}" onclick="setMainImage('${photo.id}')" title="Set as Main">
                            <i data-lucide="star" style="width:14px;height:14px;"></i>
                        </button>
                        <button type="button" class="action-icon btn-remove-photo" onclick="removePhoto('${photo.id}')" title="Remove">
                            <i data-lucide="trash-2" style="width:14px;height:14px;"></i>
                        </button>
                    </div>
                    ${photo.isMain ? `
                        <div class="main-badge">
                            <i data-lucide="check-circle" style="width:12px;height:12px;"></i> Main Image
                        </div>
                    ` : ''}
                `;
                    photoPreviewGrid.appendChild(card);
                });

                if (window.lucide) lucide.createIcons();
            }

            window.setMainImage = function (id) {
                propertyPhotos.forEach(p => p.isMain = (p.id === id));
                renderPhotoPreviews();
            }

            window.removePhoto = function (id) {
                const index = propertyPhotos.findIndex(p => p.id === id);
                const wasMain = propertyPhotos[index].isMain;
                propertyPhotos.splice(index, 1);

                // If we removed the main image and have others, make the first one the new main
                if (wasMain && propertyPhotos.length > 0) {
                    propertyPhotos[0].isMain = true;
                }

                renderPhotoPreviews();
            }

            document.addEventListener('DOMContentLoaded', () => {
                if (window.lucide) lucide.createIcons();
            });

            // AJAX Form Submission
            const propertyForm = document.getElementById('property-form');
            propertyForm.addEventListener('submit', async (e) => {
                e.preventDefault();

                // Final sync for Quill editors if needed
                document.getElementById('propertyDescription').value = quill.root.innerHTML;
                document.getElementById('additionalInfo').value = amenityQuill.root.innerHTML;
                document.getElementById('paymentTermsInput').value = paymentQuill.root.innerHTML;

                const formData = new FormData(propertyForm);

                // Add photos from our custom JS array
                propertyPhotos.forEach((photo, index) => {
                    formData.append('photos', photo.file);
                    if (photo.isMain) {
                        formData.set('mainPhotoIndex', index);
                    }
                });

                // Show loading state
                const submitBtn = e.submitter || propertyForm.querySelector('button[type="submit"]');
                const originalBtnText = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = 'Saving...';

                try {
                    const response = await fetch('/api/admin/properties/add', {
                        method: 'POST',
                        body: formData
                    });

                    const result = await response.json();

                    if (response.ok) {

                        const alertBox = document.getElementById('alert');
                        alertBox.textContent = 'Property saved successfully!';
                        alertBox.className = 'alert alert-success';
                        alertBox.style.display = 'block';
                        setTimeout(() => { window.location.href = '/api/admin/properties'; }, 1500);
                    } else {

                        const alertBox = document.getElementById('alert');
                        alertBox.textContent = 'Error saving property: ' + (result.message || 'Unknown error');
                        alertBox.className = 'alert alert-error';
                        alertBox.style.display = 'block';
                    }
                } catch (error) {
                    console.error('Submission error:', error);

                    const alertBox = document.getElementById('alert');
                    alertBox.textContent = 'An unexpected error occurred. Please check the console.';
                    alertBox.className = 'alert alert-error';
                    alertBox.style.display = 'block';
                } finally {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnText;
                }
            });
        </script>
    </body>

</html>