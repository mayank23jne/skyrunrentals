model PropertyExtra {
  id               Int      @id @default(autoincrement())
  propertyId       Int      @map("property_id")
  petFee           String?  @map("pet_fee") @db.VarChar(255)
  cleaningFee      String?  @map("cleaning_fee") @db.VarChar(255)
  taxes            String?  @map("taxes") @db.VarChar(255)
  damageProtection String?  @map("damage_protection") @db.VarChar(255)
  paymentTerms     String?  @map("payment_terms") @db.Text
  property         Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId], map: "property_extras_property_id_fkey")
  @@map("property_extras")
}

model PropertyType {
  id           Int    @id @default(autoincrement())
  propertyName String @map("property_name") @db.VarChar(255)

  @@map("property_type")
}

model PropertyView {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(255)

  @@map("property_view")
}

model Rate {
  id           Int       @id @default(autoincrement())
  propertyId   Int       @map("property_id")
  seasonName   String?   @map("season_name") @db.VarChar(255)
  startDate    DateTime? @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  minimumStay  String?   @map("minimum_stay") @db.VarChar(255)
  weekendNight String?   @map("weekend_night") @db.VarChar(255)
  nightly      Float?
  weekly       String?   @db.VarChar(255)
  monthly      String?   @db.VarChar(255)
  property     Property  @relation(fields: [propertyId], references: [id])

  @@index([propertyId], map: "rates_property_id_fkey")
  @@map("rates")
}

model State {
  id        Int     @id @default(autoincrement())
  name      String  @db.VarChar(30)
  image     String  @db.VarChar(100)
  stunning  Int?    @default(0)
  countryId Int     @default(1) @map("country_id")
  cities    City[]
  country   Country @relation(fields: [countryId], references: [id])

  @@index([countryId], map: "states_country_id_fkey")
  @@map("states")
}

model TermCondition {
  id     Int    @id @default(autoincrement())
  title  String @db.VarChar(255)
  detail String @db.LongText

  @@map("term_condition")
}

enum StartDay {
  mon
  sun
}

enum DateFormat {
  us
  eu
}

enum ClickPastDates {
  on
  off
}

model AmenityCategory {
  id        Int          @id @default(autoincrement())
  name      String       @db.VarChar(255)
  items     AmenityItem[]

  @@map("amenitycategory")
}

model AmenityItem {
  id               Int               @id @default(autoincrement())
  categoryId       Int
  name             String            @db.VarChar(255)
  icon             String?           @db.VarChar(255)
  category         AmenityCategory   @relation(fields: [categoryId], references: [id])
  propertyAmenities PropertyAmenity[]

  @@map("amenityitem")
}

model PropertyAmenity {
  id            Int         @id @default(autoincrement())
  propertyId    Int
  amenityItemId Int
  property      Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenityItem   AmenityItem @relation(fields: [amenityItemId], references: [id], onDelete: Cascade)

  @@map("propertyamenity")
}
