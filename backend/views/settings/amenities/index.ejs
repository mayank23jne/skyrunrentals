<!DOCTYPE html>
<html lang="en">
<%- include('../../partials/head') %>

    <body>
        <div class="layout">
            <%- include('../../partials/sidebar', { activePage: 'settings-amenities' }) %>
                <main>
                    <%- include('../../partials/header', { pageTitle: 'Amenities Master' }) %>

                        <style>
                            .grid-container {
                                display: grid;
                                grid-template-columns: 1fr 2fr;
                                gap: 1.5rem;
                            }

                            @media (max-width: 992px) {
                                .grid-container {
                                    grid-template-columns: 1fr;
                                }
                            }

                            .data-table {
                                width: 100%;
                                border-collapse: separate;
                                border-spacing: 0;
                            }

                            .data-table th {
                                text-align: left;
                                padding: 1rem;
                                color: var(--text-muted);
                                font-weight: 600;
                                font-size: 0.875rem;
                                border-bottom: 1px solid var(--border);
                                background-color: #fafbfc;
                                position: sticky;
                                top: 0;
                                z-index: 10;
                            }

                            .data-table td {
                                padding: 1rem;
                                border-bottom: 1px solid var(--border);
                                font-size: 0.9375rem;
                                vertical-align: middle;
                            }

                            .scrollable-table-container {
                                max-height: 500px;
                                overflow-y: auto;
                                overflow-x: auto;
                                border: 1px solid var(--border);
                                border-radius: 0.5rem;
                            }

                            .action-btns {
                                display: flex;
                                gap: 0.5rem;
                            }

                            .action-btn {
                                width: 32px;
                                height: 32px;
                                border-radius: 0.5rem;
                                border: 1px solid var(--border);
                                background: white;
                                color: var(--text-muted);
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                transition: all 0.2s ease;
                                cursor: pointer;
                            }

                            .btn-edit:hover {
                                color: #f59e0b;
                                border-color: #f59e0b;
                                background-color: #fffbeb;
                            }

                            .btn-delete:hover {
                                color: #ef4444;
                                border-color: #ef4444;
                                background-color: #fef2f2;
                            }

                            /* Modal Styles */
                            .modal-overlay {
                                position: fixed;
                                inset: 0;
                                background: rgba(0, 0, 0, 0.5);
                                backdrop-filter: blur(4px);
                                display: none;
                                align-items: center;
                                justify-content: center;
                                z-index: 1000;
                                padding: 1rem;
                            }

                            .modal-content {
                                background: white;
                                border-radius: 1.5rem;
                                width: 100%;
                                max-width: 400px;
                                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.2);
                                overflow: hidden;
                                animation: modalIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
                            }

                            @keyframes modalIn {
                                from {
                                    opacity: 0;
                                    transform: translateY(24px) scale(0.97);
                                }

                                to {
                                    opacity: 1;
                                    transform: translateY(0) scale(1);
                                }
                            }

                            .modal-header {
                                padding: 1.5rem 2rem;
                                border-bottom: 1px solid var(--border);
                                display: flex;
                                justify-content: space-between;
                                align-items: center;
                                background: linear-gradient(135deg, #f8f9ff 0%, #ffffff 100%);
                            }

                            .modal-header h3 {
                                font-size: 1.1rem;
                                font-weight: 700;
                                color: var(--text-main);
                                margin: 0;
                            }

                            .modal-close-btn {
                                background: #f1f5f9;
                                border: none;
                                cursor: pointer;
                                color: var(--text-muted);
                                width: 32px;
                                height: 32px;
                                border-radius: 50%;
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                transition: all 0.2s;
                            }

                            .modal-close-btn:hover {
                                background: #fee2e2;
                                color: #ef4444;
                            }

                            .modal-body {
                                padding: 1.5rem 2rem;
                            }

                            .modal-footer {
                                padding: 1.25rem 2rem;
                                background: #fafbfc;
                                border-top: 1px solid var(--border);
                                display: flex;
                                justify-content: flex-end;
                                gap: 0.75rem;
                            }

                            .form-group {
                                margin-bottom: 1.25rem;
                                display: flex;
                                flex-direction: column;
                                gap: 0.4rem;
                            }

                            .form-group label {
                                font-size: 0.8125rem;
                                font-weight: 600;
                                color: var(--text-muted);
                                text-transform: uppercase;
                                letter-spacing: 0.04em;
                            }

                            .form-group input,
                            .form-group select {
                                padding: 0.75rem 1rem;
                                border-radius: 0.75rem;
                                border: 1.5px solid var(--border);
                                outline: none;
                                width: 100%;
                                box-sizing: border-box;
                            }

                            .form-group input:focus,
                            .form-group select:focus {
                                border-color: var(--primary);
                            }

                            .cat-row {
                                cursor: pointer;
                                transition: background 0.2s;
                            }

                            .cat-row:hover {
                                background: #f8fafc;
                            }

                            .cat-row.active {
                                background: #eff6ff;
                                border-left: 3px solid var(--primary);
                            }
                        </style>

                        <div class="grid-container">
                            <!-- Categories Card -->
                            <div class="card" style="align-self: start;">
                                <div
                                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                                    <h3 style="margin: 0;">Categories</h3>
                                    <button onclick="openCategoryModal()" class="btn-primary"
                                        style="padding: 0.5rem 1rem; font-size: 0.875rem;">
                                        <i data-lucide="plus" style="width: 14px; height: 14px;"></i> Add
                                    </button>
                                </div>
                                <div class="scrollable-table-container">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th style="width: 80px;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% categories.forEach((cat, idx)=> { %>
                                                <tr class="cat-row <%= idx === 0 ? 'active' : '' %>"
                                                    onclick="selectCategory('<%= cat.id %>', this)">
                                                    <td><strong>
                                                            <%= cat.name %>
                                                        </strong></td>
                                                    <td>
                                                        <div class="action-btns">
                                                            <button class="action-btn btn-edit"
                                                                onclick="event.stopPropagation(); openCategoryModal({id: '<%= cat.id %>', name: '<%= cat.name %>'})">
                                                                <i data-lucide="edit-2"
                                                                    style="width:14px; height:14px;"></i>
                                                            </button>
                                                            <button class="action-btn btn-delete"
                                                                onclick="event.stopPropagation(); deleteCategory('<%= cat.id %>')">
                                                                <i data-lucide="trash-2"
                                                                    style="width:14px; height:14px;"></i>
                                                            </button>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% if(categories.length===0) { %>
                                                        <tr>
                                                            <td colspan="2"
                                                                style="text-align: center; color: var(--text-muted);">No
                                                                categories found.</td>
                                                        </tr>
                                                        <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- Items Card -->
                            <div class="card" style="align-self: start;">
                                <div
                                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                                    <h3 style="margin: 0;">Amenities</h3>
                                    <button onclick="openItemModal()" class="btn-primary"
                                        style="padding: 0.5rem 1rem; font-size: 0.875rem;">
                                        <i data-lucide="plus" style="width: 14px; height: 14px;"></i> Add Item
                                    </button>
                                </div>
                                <div class="scrollable-table-container">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>Icon</th>
                                                <th>Amenity Name</th>
                                                <th style="width: 80px;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody id="items-tbody">
                                            <!-- Populated by JS based on selected category -->
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                </main>
        </div>

        <!-- Category Modal -->
        <div class="modal-overlay" id="category-modal" onclick="if(event.target===this) this.style.display='none'">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 id="cat-modal-title">Add Category</h3>
                    <button class="modal-close-btn"
                        onclick="document.getElementById('category-modal').style.display='none'">
                        <i data-lucide="x" style="width:16px;height:16px;"></i>
                    </button>
                </div>
                <form id="category-form">
                    <input type="hidden" id="cat-id" name="id">
                    <div class="modal-body">
                        <div class="form-group">
                            <label>Category Name</label>
                            <input type="text" name="name" id="cat-name" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Item Modal -->
        <div class="modal-overlay" id="item-modal" onclick="if(event.target===this) this.style.display='none'">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 id="item-modal-title">Add Amenity</h3>
                    <button class="modal-close-btn"
                        onclick="document.getElementById('item-modal').style.display='none'">
                        <i data-lucide="x" style="width:16px;height:16px;"></i>
                    </button>
                </div>
                <form id="item-form">
                    <input type="hidden" id="item-id" name="id">
                    <input type="hidden" id="item-categoryId" name="categoryId">
                    <div class="modal-body">
                        <div class="form-group">
                            <label>Amenity Name</label>
                            <input type="text" name="name" id="item-name" required>
                        </div>
                        <div class="form-group">
                            <label>Icon (Optional)</label>
                            <input type="text" name="icon" id="item-icon">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>

        <script>
            const categories = <%- JSON.stringify(categories || []) %>;
            let selectedCategoryId = categories.length > 0 ? categories[0].id : null;

            function renderItems() {
                const tbody = document.getElementById('items-tbody');
                if (!selectedCategoryId) {
                    tbody.innerHTML = '<tr><td colspan="3" style="text-align: center;">Select a category to view items</td></tr>';
                    return;
                }

                const category = categories.find(c => String(c.id) === String(selectedCategoryId));
                const items = category && category.items ? category.items : [];

                if (items.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="3" style="text-align: center; color: var(--text-muted);">No amenities in this category.</td></tr>';
                    return;
                }

                let html = '';
                items.forEach(item => {
                    html += `
                    <tr>
                        <td>${item.icon ? '<i class="' + item.icon + '" style="color: #64748b;"></i>' : '-'}</td>
                        <td><strong>${item.name}</strong></td>
                        <td>
                            <div class="action-btns">
                                <button class="action-btn btn-edit" onclick="openItemModal({id: '${item.id}', name: '${item.name.replace(/'/g, "\\'")}', icon: '${(item.icon || '').replace(/'/g, "\\'")}'})">
                                    <i data-lucide="edit-2" style="width:14px; height:14px;"></i>
                                </button>
                                <button class="action-btn btn-delete" onclick="deleteItem('${item.id}')">
                                    <i data-lucide="trash-2" style="width:14px; height:14px;"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
                });
                tbody.innerHTML = html;
                lucide.createIcons();
            }

            function selectCategory(id, el) {
                selectedCategoryId = id;
                document.querySelectorAll('.cat-row').forEach(row => row.classList.remove('active'));
                if (el) el.classList.add('active');
                renderItems();
            }

            // Init
            document.addEventListener('DOMContentLoaded', () => {
                renderItems();
                lucide.createIcons();
            });

            // Categories CRUD
            function openCategoryModal(data = null) {
                const modal = document.getElementById('category-modal');
                const form = document.getElementById('category-form');
                form.reset();
                if (data) {
                    document.getElementById('cat-modal-title').textContent = 'Edit Category';
                    document.getElementById('cat-id').value = data.id;
                    document.getElementById('cat-name').value = data.name;
                } else {
                    document.getElementById('cat-modal-title').textContent = 'Add Category';
                    document.getElementById('cat-id').value = '';
                }
                modal.style.display = 'flex';
            }

            document.getElementById('category-form').addEventListener('submit', async (e) => {
                e.preventDefault();
                const id = document.getElementById('cat-id').value;
                const name = document.getElementById('cat-name').value;
                const url = id ? `/api/admin/settings/amenity-categories/${id}/update` : `/api/admin/settings/amenity-categories`;

                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name })
                });

                if (res.ok) window.location.reload();
                else alert('Failed to save category');
            });

            async function deleteCategory(id) {
                if (!confirm('Are you sure you want to delete this category? All associated amenities will also be deleted.')) return;
                const res = await fetch(`/api/admin/settings/amenity-categories/${id}/delete`, { method: 'POST' });
                if (res.ok) window.location.reload();
            }

            // Items CRUD
            function openItemModal(data = null) {
                if (!selectedCategoryId) return alert('Please select a category first.');
                const modal = document.getElementById('item-modal');
                const form = document.getElementById('item-form');
                form.reset();
                document.getElementById('item-categoryId').value = selectedCategoryId;

                if (data) {
                    document.getElementById('item-modal-title').textContent = 'Edit Amenity';
                    document.getElementById('item-id').value = data.id;
                    document.getElementById('item-name').value = data.name;
                    document.getElementById('item-icon').value = data.icon || '';
                } else {
                    document.getElementById('item-modal-title').textContent = 'Add Amenity';
                    document.getElementById('item-id').value = '';
                }
                modal.style.display = 'flex';
            }

            document.getElementById('item-form').addEventListener('submit', async (e) => {
                e.preventDefault();
                const id = document.getElementById('item-id').value;
                const name = document.getElementById('item-name').value;
                const icon = document.getElementById('item-icon').value;
                const categoryId = document.getElementById('item-categoryId').value;

                const url = id ? `/api/admin/settings/amenity-items/${id}/update` : `/api/admin/settings/amenity-items`;

                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, icon, categoryId })
                });

                if (res.ok) window.location.reload();
                else alert('Failed to save amenity');
            });

            async function deleteItem(id) {
                if (!confirm('Are you sure you want to delete this amenity?')) return;
                const res = await fetch(`/api/admin/settings/amenity-items/${id}/delete`, { method: 'POST' });
                if (res.ok) window.location.reload();
            }
        </script>
    </body>

</html>