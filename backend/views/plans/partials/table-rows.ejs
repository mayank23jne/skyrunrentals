<% if (plans && plans.length > 0) { %>
    <% plans.forEach(plan => { %>
        <tr id="plan-<%= plan.id %>">
            <td><div style="font-weight: 600; color: var(--text-main);"><%= plan.planName %></div></td>
            <td><div style="font-weight: 700; color: var(--primary);">$<%= plan.price %></div></td>
            <td style="color: var(--text-muted); font-size: 0.875rem; max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                <%= plan.description1 %>
            </td>
            <td>
                <div class="action-btns">
                    <a href="/api/admin/settings/plans/<%= plan.id %>/edit" class="action-btn btn-edit" title="Edit Plan">
                        <i data-lucide="edit-3"></i>
                    </a>
                    <button class="action-btn btn-delete btn-delete-plan" data-id="<%= plan.id %>" title="Delete Plan">
                        <i data-lucide="trash-2"></i>
                    </button>
                </div>
            </td>
        </tr>
    <% }) %>
<% } else { %>
    <tr>
        <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 4rem;">
            <i data-lucide="package" size="48" style="opacity: 0.2; margin-bottom: 1rem;"></i>
            <p>No subscription plans found matching your criteria.</p>
        </td>
    </tr>
<% } %>

<!-- Pagination Data (Hidden) -->
<tr style="display: none;">
    <td colspan="4">
        <div id="pagination-data" 
             data-current-page="<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>" 
             data-total-pages="<%= typeof totalPages !== 'undefined' ? totalPages : 1 %>" 
             data-total-count="<%= typeof totalCount !== 'undefined' ? totalCount : 0 %>">
        </div>
    </td>
</tr>
