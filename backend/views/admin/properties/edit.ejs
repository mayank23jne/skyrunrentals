        <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                try {
                    if (typeof lucide !== 'undefined') lucide.createIcons();

                    const quillConfig = {
                        theme: 'snow',
                        modules: {
                            toolbar: [
                                ['bold', 'italic', 'underline'],
                                [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                                ['clean']
                            ]
                        }
                    };

                    // Initialize editors
                    const editorMap = [
                        { id: '#editor-container', input: '#propertyDescriptionInput', name: 'descQuill' },
                        { id: '#additional-info-editor', input: '#additionalInfoInput', name: 'amenityQuill' },
                        { id: '#payment-terms-editor', input: '#paymentTermsInput', name: 'paymentTermsQuill' }
                    ];

                    editorMap.forEach(ed => {
                        const container = document.querySelector(ed.id);
                        if (container) {
                            window[ed.name] = new Quill(ed.id, quillConfig);
                        }
                    });

                    // Update hidden inputs on form submission
                    const form = document.getElementById('edit-property-form');
                    if (form) {
                        form.addEventListener('submit', (e) => {
                            editorMap.forEach(ed => {
                                if (window[ed.name]) {
                                    const input = document.querySelector(ed.input);
                                    if (input) input.value = window[ed.name].root.innerHTML;
                                }
                            });
                        });
                    }

                    // Reusable location logic
                    const setupLocationDependency = (countryEl, stateEl, cityEl) => {
                        if (!countryEl || !stateEl || !cityEl) return;

                        countryEl.addEventListener('change', async () => {
                            const selectedOption = countryEl.options[countryEl.selectedIndex];
                            const countryId = countryEl.value;

                            stateEl.innerHTML = '<option value="">Select State</option>';
                            cityEl.innerHTML = '<option value="">Select City</option>';

                            if (!countryId) return;

                            try {
                                const response = await fetch(`/api/admin/settings/data/states?countryId=${countryId}`);
                                const statesData = await response.json();
                                statesData.forEach(s => {
                                    const opt = document.createElement('option');
                                    opt.value = s.id; opt.setAttribute("data-name", s.name);
                                    opt.textContent = s.name;
                                    stateEl.appendChild(opt);
                                });
                            } catch (error) {
                                console.error('Failed to fetch states:', error);
                            }
                        });

                        stateEl.addEventListener('change', async () => {
                            const selectedOption = stateEl.options[stateEl.selectedIndex];
                            const stateId = stateEl.value;

                            cityEl.innerHTML = '<option value="">Select City</option>';

                            if (!stateId) return;

                            try {
                                const response = await fetch(`/api/admin/settings/data/cities?stateId=${stateId}`);
                                const citiesData = await response.json();
                                citiesData.forEach(c => {
                                    const opt = document.createElement('option');
                                    opt.value = c.id; opt.setAttribute("data-name", c.name);
                                    opt.textContent = c.name;
                                    cityEl.appendChild(opt);
                                });
                            } catch (error) {
                                console.error('Failed to fetch cities:', error);
                            }
                        });
                    };

                    // Initialize location dependencies for both main and contact
                    setupLocationDependency(
                        document.getElementById('country-select'),
                        document.getElementById('state-select'),
                        document.getElementById('city-select')
                    );

                    setupLocationDependency(
                        document.getElementById('contact-country-select'),
                        document.getElementById('contact-state-select'),
                        document.getElementById('contact-city-select')
                    );

                } catch (e) {
                    console.error('Initialization failed:', e);
                }

                // Tab items click logic
                document.querySelectorAll('.tab-item').forEach(item => {
                    item.addEventListener('click', () => {
                        const tabNum = parseInt(item.dataset.tab);
                        nextTab(tabNum);
                    });
                });

                try {
                    renderPropertiesCalendar();
                    renderRatesTable();
                } catch (e) {
                    console.error('Table/Calendar initialization failed:', e);
                }

                // Initial tab switch if requested
                const urlParams = new URLSearchParams(window.location.search);
                const initialTab = urlParams.get('tab');
                if (initialTab && !isNaN(parseInt(initialTab))) {
                    setTimeout(() => nextTab(parseInt(initialTab)), 100);
                }
            });

            let currentTab = 1;
            const removedPhotos = [];

            function nextTab(n) {
                if (n > 6 || n < 1) return;
                const targetTab = document.getElementById('tab-' + n);
                const targetNav = document.querySelector(`[data-tab="${n}"]`);

                if (!targetTab || !targetNav) {
                    console.error(`Tab ${n} not found`);
                    return;
                }

                document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));

                targetTab.classList.add('active');
                targetNav.classList.add('active');

                const progress = document.querySelector('.progress-bar');
                if (progress) {
                    progress.style.width = ((n / 6) * 100) + '%';
                }

                currentTab = n;
                window.scrollTo(0, 0);
            }

            function prevTab(n) {
                nextTab(n);
            }

            function removeExistingPhoto(id, btn) {
                removedPhotos.push(id);
                document.getElementById('removedPhotosInput').value = removedPhotos.join(',');
                btn.closest('.photo-card').style.display = 'none';
            }

            function setMainPhoto(id, btn) {
                document.querySelectorAll('.btn-main-photo').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                document.getElementById('mainPhotoIdInput').value = id;
            }

            const photoInput = document.getElementById('photo-input');
            const previewGrid = document.getElementById('photo-preview-grid');
            let newFiles = [];

            photoInput.addEventListener('change', (e) => {
                const files = Array.from(e.target.files);
                files.forEach(file => {
                    newFiles.push(file);
                    const reader = new FileReader();
                    reader.onload = (re) => {
                        const div = document.createElement('div');
                        div.className = 'photo-card';
                        div.innerHTML = `<img src="${re.target.result}"><div class="photo-actions"><button type="button" class="action-icon btn-remove-photo" onclick="removeNewPhoto(this, ${newFiles.length - 1})"><i data-lucide="x" size="14"></i></button></div>`;
                        previewGrid.appendChild(div);
                        if (window.lucide) lucide.createIcons();
                    }
                    reader.readAsDataURL(file);
                });
            });

            function removeNewPhoto(btn, index) {
                newFiles[index] = null;
                btn.closest('.photo-card').remove();
            }

            // let paymentTermsQuill = new Quill('#payment-terms-editor', quillConfig); // Moved to DOMContentLoaded
            let seasonalRates = <%- JSON.stringify(property.rates || []) %>;
            let editingRateIndex = -1;

            // Calendar Logic
            let calendarYear = new Date().getFullYear();
            let calendarMonth = new Date().getMonth();
            let blockedDates = <%- JSON.stringify(property.calendarBlockedDates || {}) %>;

            function renderPropertiesCalendar() {
                const container = document.getElementById('calendar-render-area');
                if (!container) return;
                container.innerHTML = '';

                // Render 4 months starting from current calendar state
                for (let i = 0; i < 4; i++) {
                    let m = calendarMonth + i;
                    let y = calendarYear;
                    if (m > 11) {
                        m -= 12; y++;
                    }
                    container.appendChild(generateMonthElement(y, m));
                }
                if (window.lucide) lucide.createIcons();
            }

            function generateMonthElement(year, month) {
                const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
                const div = document.createElement('div');
                div.className = 'calendar-month';

                let html = `
                    <div class="month-header">${monthNames[month]} ${year}</div>
                    <div class="weekdays-grid">
                        <div>M</div><div>T</div><div>W</div><div>T</div><div>F</div><div>S</div><div>S</div>
                    </div>
                    <div class="days-grid">
                `;

                const firstDay = new Date(year, month, 1).getDay();
                const daysInMonth = new Date(year, month + 1, 0).getDate();
                let startingPadding = firstDay === 0 ? 6 : firstDay - 1;

                const prevMonthDays = new Date(year, month, 0).getDate();
                for (let i = startingPadding - 1; i >= 0; i--) {
                    html += `<div class="day-cell other-month">${prevMonthDays - i}</div>`;
                }

                const today = new Date();
                for (let d = 1; d <= daysInMonth; d++) {
                    const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
                    const status = blockedDates[dateStr] || '';
                    const isToday = today.getFullYear() === year && today.getMonth() === month && today.getDate() === d;

                    let statusClass = '';
                    if (status === 'booked') statusClass = 'status-booked';
                    else if (status === 'am') statusClass = 'status-booked-am';
                    else if (status === 'pm') statusClass = 'status-booked-pm';

                    html += `
                        <div class="day-cell ${isToday ? 'today' : ''} ${statusClass}" 
                             data-date="${dateStr}" onclick="handleDateClick(this)">
                            ${d}
                        </div>
                    `;
                }
                html += `</div>`;
                div.innerHTML = html;
                return div;
            }

            function handleDateClick(el) {
                const dateStr = el.dataset.date;
                if (!dateStr) return;

                const method = document.querySelector('.click-method-select').value;
                let currentStatus = blockedDates[dateStr] || 'available';

                if (method === 'cycle') {
                    if (currentStatus === 'available') currentStatus = 'booked';
                    else if (currentStatus === 'booked') currentStatus = 'am';
                    else if (currentStatus === 'am') currentStatus = 'pm';
                    else currentStatus = 'available';
                } else {
                    currentStatus = method;
                }

                if (currentStatus === 'available') {
                    delete blockedDates[dateStr];
                } else {
                    blockedDates[dateStr] = currentStatus;
                }

                el.classList.remove('status-booked', 'status-booked-am', 'status-booked-pm');
                if (currentStatus === 'booked') el.classList.add('status-booked');
                else if (currentStatus === 'am') el.classList.add('status-booked-am');
                else if (currentStatus === 'pm') el.classList.add('status-booked-pm');

                document.getElementById('calendarBlockedDatesInput').value = JSON.stringify(blockedDates);
            }

            function nextMonth() { calendarMonth++; if (calendarMonth > 11) { calendarMonth = 0; calendarYear++; } renderPropertiesCalendar(); }
            function prevMonth() { calendarMonth--; if (calendarMonth < 0) { calendarMonth = 11; calendarYear--; } renderPropertiesCalendar(); }
            function nextYear() { calendarYear++; renderPropertiesCalendar(); }
            function prevYear() { calendarYear--; renderPropertiesCalendar(); }

            // Initialize calendar
            // renderPropertiesCalendar(); // Moved to DOMContentLoaded

            function renderRatesTable() {
                const tbody = document.getElementById('rates-table-body');
                tbody.innerHTML = '';
                seasonalRates.forEach((rate, index) => {
                    const row = document.createElement('tr');
                    row.style.borderBottom = '1px solid #edf2f9';
                    const formatDate = (dateStr) => {
                        if (!dateStr) return '0000-00-00';
                        try {
                            const d = new Date(dateStr);
                            if (isNaN(d.getTime())) return '0000-00-00';
                            return d.toISOString().split('T')[0];
                        } catch (e) {
                            return '0000-00-00';
                        }
                    };

                    row.innerHTML = `
                        <td style="padding: 1rem;">${rate.seasonName || ''}</td>
                        <td style="padding: 1rem;">${formatDate(rate.startDate)}</td>
                        <td style="padding: 1rem;">${formatDate(rate.endDate)}</td>
                        <td style="padding: 1rem;">${rate.minimumStay || ''}</td>
                        <td style="padding: 1rem;">${rate.nightly || ''}</td>
                        <td style="padding: 1rem;">${rate.weekly || ''}</td>
                        <td style="padding: 1rem;">${rate.weekendNight || ''}</td>
                        <td style="padding: 1rem;">${rate.monthly || ''}</td>
                        <td style="padding: 1rem;">
                            <div style="display: flex; gap: 0.5rem;">
                                <button type="button" class="action-icon" onclick="editRate(${index})" style="background: none; border: none; cursor: pointer; color: #3498db;"><i data-lucide="edit-2" size="14"></i></button>
                                <button type="button" class="action-icon" onclick="deleteRate(${index})" style="background: none; border: none; cursor: pointer; color: #e74c3c;"><i data-lucide="trash-2" size="14"></i></button>
                            </div>
                        </td>
                    `;
                    tbody.appendChild(row);
                });
                document.getElementById('seasonalRatesInput').value = JSON.stringify(seasonalRates);
                if (window.lucide) lucide.createIcons();
            }

            function saveRate() {
                // Clear previous errors
                ['rate-season-name', 'rate-start-date', 'rate-end-date', 'rate-min-stay', 'rate-nightly'].forEach(id => {
                    const errEl = document.getElementById('err-' + id);
                    if(errEl) {
                        errEl.style.display = 'none';
                        errEl.textContent = '';
                    }
                    document.getElementById(id).style.borderColor = '';
                });

                const rate = {
                    seasonName: document.getElementById('rate-season-name').value.trim(),
                    startDate: document.getElementById('rate-start-date').value,
                    endDate: document.getElementById('rate-end-date').value,
                    minStay: document.getElementById('rate-min-stay').value,
                    weekendNight: document.getElementById('rate-weekend-night').value,
                    nightly: document.getElementById('rate-nightly').value,
                    weekly: document.getElementById('rate-weekly').value,
                    monthly: document.getElementById('rate-monthly').value
                };

                let isValid = true;

                const showError = (id, msg) => {
                    isValid = false;
                    const errEl = document.getElementById('err-' + id);
                    if(errEl) {
                        errEl.style.display = 'block';
                        errEl.textContent = msg;
                    }
                    document.getElementById(id).style.borderColor = '#e74c3c';
                };

                if (!rate.seasonName) showError('rate-season-name', 'Season name is required');
                if (!rate.startDate) showError('rate-start-date', 'Start date is required');
                if (!rate.endDate) showError('rate-end-date', 'End date is required');
                if (!rate.minStay) showError('rate-min-stay', 'Minimum stay is required');
                if (!rate.nightly) showError('rate-nightly', 'Nightly rate is required');

                if (!isValid) return;

                if (editingRateIndex > -1) {
                    seasonalRates[editingRateIndex] = rate;
                    editingRateIndex = -1;
                    const btn = document.querySelector('.btn-save-rate');
                    btn.textContent = 'Save';
                    btn.style.background = '#1abc9c';
                } else {
                    seasonalRates.push(rate);
                }

                renderRatesTable();
                clearRateForm();
            }

            function editRate(index) {
                const rate = seasonalRates[index];
                document.getElementById('rate-season-name').value = rate.seasonName || '';
                document.getElementById('rate-start-date').value = rate.startDate ? new Date(rate.startDate).toISOString().split('T')[0] : '';
                document.getElementById('rate-end-date').value = rate.endDate ? new Date(rate.endDate).toISOString().split('T')[0] : '';
                document.getElementById('rate-min-stay').value = rate.minimumStay || rate.minStay || '';
                document.getElementById('rate-weekend-night').value = rate.weekendNight || '';
                document.getElementById('rate-nightly').value = rate.nightly || '';
                document.getElementById('rate-weekly').value = rate.weekly || '';
                document.getElementById('rate-monthly').value = rate.monthly || '';

                editingRateIndex = index;
                const btn = document.querySelector('.btn-save-rate');
                btn.textContent = 'Update';
                btn.style.background = '#3498db';
                document.querySelector('.rate-entry-panel').scrollIntoView({ behavior: 'smooth' });
            }

            async function deleteRate(index) {
                const confirmed = await openDeleteModal('Delete Rate', 'Are you sure you want to delete this rate?');
                if (confirmed) {
                    seasonalRates.splice(index, 1);
                    renderRatesTable();
                }
            }

            function clearRateForm() {
                document.getElementById('rate-season-name').value = '';
                document.getElementById('rate-start-date').value = '';
                document.getElementById('rate-end-date').value = '';
                document.getElementById('rate-min-stay').value = '';
                document.getElementById('rate-weekend-night').value = '';
                document.getElementById('rate-nightly').value = '';
                document.getElementById('rate-weekly').value = '';
                document.getElementById('rate-monthly').value = '';
                editingRateIndex = -1;
                const btn = document.querySelector('.btn-save-rate');
                btn.textContent = 'Save';
                btn.style.background = '#1abc9c';
            }

            // Initialize table
            // renderRatesTable(); // Moved to DOMContentLoaded

            document.getElementById('edit-property-form').addEventListener('submit', async (e) => {
                e.preventDefault();
                const form = e.target;
                const submitBtn = e.submitter || form.querySelector('button[type="submit"]');
                const originalBtnText = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = 'Saving...';

                if (window.descQuill) document.getElementById('propertyDescriptionInput').value = window.descQuill.root.innerHTML;
                if (window.amenityQuill) document.getElementById('additionalInfoInput').value = window.amenityQuill.root.innerHTML;
                if (window.paymentTermsQuill) document.getElementById('paymentTermsInput').value = window.paymentTermsQuill.root.innerHTML;
                document.getElementById('seasonalRatesInput').value = JSON.stringify(seasonalRates);
                document.getElementById('calendarBlockedDatesInput').value = JSON.stringify(blockedDates);

                const formData = new FormData(form);
                newFiles.filter(f => f !== null).forEach(f => formData.append('photos', f));

                try {
                    const response = await fetch(`/api/admin/properties/<%=property.id%>/edit`, {
                        method: 'POST',
                        body: formData
                    });

                    if (response.ok) {
                        const alertBox = document.getElementById('alert');
                        alertBox.textContent = 'Property updated successfully!';
                        alertBox.className = 'alert alert-success';
                        alertBox.style.display = 'block';
                        alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        
                        submitBtn.innerHTML = 'Saved Successfully!';
                        setTimeout(() => { window.location.href = '/admin/properties'; }, 1500);
                        return; // Prevent resetting button text before redirect
                    } else {
                        const err = await response.json();

                        const alertBox = document.getElementById('alert');
                        alertBox.textContent = 'Error: ' + err.message;
                        alertBox.className = 'alert alert-error';
                        alertBox.style.display = 'block';
                        alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        setTimeout(() => { alertBox.style.display = 'none'; }, 5000);
                    }
                } catch (error) {
                    console.error('Update error:', error);

                    const alertBox = document.getElementById('alert');
                    alertBox.textContent = 'An error occurred during update.';
                    alertBox.className = 'alert alert-error';
                    alertBox.style.display = 'block';
                    alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    setTimeout(() => { alertBox.style.display = 'none'; }, 5000);
                } 
                
                // Reset button text if an error occurred
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnText;
            });
        </script>
    </body>

</html>