<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
    <div class="layout">
        <%- include('../partials/sidebar', { activePage: 'settings-plans' }) %>
        <main>
            <%- include('../partials/header', { pageTitle: 'Subscription Plans' }) %>
            
            <div class="card">
                <div class="controls-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                    <style>
                        .data-table { width: 100%; border-collapse: separate; border-spacing: 0; margin-bottom: 2rem; }
                        .data-table th { text-align: left; padding: 1.25rem 1.5rem; color: var(--text-muted); font-weight: 600; font-size: 0.875rem; border-bottom: 1px solid var(--border); background-color: #fafbfc; }
                        .data-table td { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border); font-size: 0.9375rem; vertical-align: middle; }
                        .action-btns { display: flex; gap: 0.75rem; }
                        .action-btn { width: 32px; height: 32px; border-radius: 0.5rem; border: 1px solid var(--border); background: white; color: var(--text-muted); display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; cursor: pointer; text-decoration: none; }
                        .btn-edit:hover { color: #f59e0b; border-color: #f59e0b; background-color: #fffbeb; }
                        .btn-delete:hover { color: #ef4444; border-color: #ef4444; background-color: #fef2f2; }
                    </style>
                    <div>
                        <h3 style="margin: 0">Manage Plans</h3>
                        <p style="color: var(--text-muted); font-size: 0.875rem">Configure subscription options for your users</p>
                    </div>
                    <div style="display: flex; gap: 1rem; align-items: center;">
                        <div class="search-box">
                            <i data-lucide="search"></i>
                            <input type="text" id="table-search" placeholder="Search plans..." value="<%= searchQuery %>">
                        </div>
                        <a href="/admin/settings/plans/create" class="btn-primary" style="text-decoration: none; display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;">
                            <i data-lucide="plus"></i> Add New Plan
                        </a>
                    </div>
                </div>

                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Plan Name</th>
                                <th>Price</th>
                                <th>Descriptions (Sample)</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="plans-table-body">
                            <%- include('partials/table-rows') %>
                        </tbody>
                    </table>
                </div>

                <!-- Pagination Footer -->
                <div class="pagination-footer">
                    <div class="pagination-info">
                        Showing <span id="start-count">1</span> to <span id="end-count">10</span> of <span id="total-count"><%= totalCount %></span> entries
                    </div>
                    <div class="pagination-controls" id="pagination-controls">
                        <!-- Controls will be rendered by JS -->
                    </div>
                </div>
            </div>
        </main>
    </div>

    <style>
        .search-box { position: relative; display: flex; align-items: center; }
        .search-box i { position: absolute; left: 1rem; width: 18px; height: 18px; color: var(--text-muted); pointer-events: none; }
        .search-box input { padding: 0.75rem 1rem 0.75rem 2.75rem; border-radius: 0.75rem; border: 1px solid var(--border); background: white; min-width: 300px; font-size: 0.875rem; outline: none; transition: all 0.2s; }
        .search-box input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }

        .pagination-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 2rem; border-top: 1px solid var(--border); margin-top: 1rem; }
        .pagination-info { font-size: 0.875rem; color: var(--text-muted); }
        .pagination-controls { display: flex; gap: 0.5rem; }
        .page-btn { padding: 0.5rem 1rem; border-radius: 0.5rem; border: 1px solid var(--border); background: white; color: var(--text-main); cursor: pointer; font-size: 0.875rem; transition: all 0.2s; }
        .page-btn:hover:not(:disabled) { border-color: var(--primary); color: var(--primary); }
        .page-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
        .page-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    </style>

    <script>
        let currentPage = 1;

        async function updateTable(page = 1, search = '') {
            const tbody = document.getElementById('plans-table-body');
            const response = await fetch(`/api/admin/settings/plans?page=${page}&search=${search}&ajax=true`);
            const html = await response.text();
            tbody.innerHTML = html;
            
            // Get data from hidden element in partial
            const dataEl = document.getElementById('pagination-data');
            if (dataEl) {
                const totalPages = parseInt(dataEl.dataset.totalPages);
                const totalCount = parseInt(dataEl.dataset.totalCount);
                currentPage = parseInt(dataEl.dataset.currentPage);
                
                renderPagination(currentPage, totalPages);
                updateInfo(currentPage, totalCount);
            }
            
            lucide.createIcons();
        }

        function renderPagination(current, total) {
            const controls = document.getElementById('pagination-controls');
            let html = `
                <button class="page-btn" ${current === 1 ? 'disabled' : ''} onclick="goToPage(${current - 1})">Previous</button>
            `;

            for (let i = 1; i <= total; i++) {
                if (i === 1 || i === total || (i >= current - 1 && i <= current + 1)) {
                    html += `<button class="page-btn ${i === current ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
                } else if (i === current - 2 || i === current + 2) {
                    html += `<span style="padding: 0.5rem">...</span>`;
                }
            }

            html += `
                <button class="page-btn" ${current === total || total === 0 ? 'disabled' : ''} onclick="goToPage(${current + 1})">Next</button>
            `;
            controls.innerHTML = html;
        }

        function updateInfo(current, total) {
            const pageSize = 10;
            const start = total === 0 ? 0 : (current - 1) * pageSize + 1;
            const end = Math.min(current * pageSize, total);
            
            document.getElementById('start-count').textContent = start;
            document.getElementById('end-count').textContent = end;
            document.getElementById('total-count').textContent = total;
        }

        function goToPage(page) {
            const search = document.getElementById('table-search').value;
            updateTable(page, search);
        }

        // Search with debounce
        let searchTimeout;
        document.getElementById('table-search').addEventListener('input', (e) => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                updateTable(1, e.target.value);
            }, 300);
        });

        // Use event delegation for delete buttons (works after AJAX updates)
        document.getElementById('plans-table-body').addEventListener('click', async (e) => {
            const btn = e.target.closest('.btn-delete-plan');
            if (btn) {
                const id = btn.dataset.id;
                const confirmed = await openDeleteModal('Delete Plan', 'Are you sure you want to delete this subscription plan?');
                if (confirmed) {
                    const response = await fetch(`/api/admin/settings/plans/${id}/delete`, { method: 'POST' });
                    if (response.ok) {
                        updateTable(currentPage, document.getElementById('table-search').value);
                    }
                }
            }
        });

        // Initial render
        const initialPage = Number("<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>");
        const initialTotalPages = Number("<%= typeof totalPages !== 'undefined' ? totalPages : 1 %>");
        const initialTotalCount = Number("<%= typeof totalCount !== 'undefined' ? totalCount : 0 %>");

        renderPagination(initialPage, initialTotalPages);
        updateInfo(initialPage, initialTotalCount);
        lucide.createIcons();
    </script>
</body>
</html>
