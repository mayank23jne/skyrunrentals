<% if (states && states.length > 0) { %>
    <% states.forEach(s => { %>
        <tr id="state-<%= s.id %>">
            <td>
                <div style="font-weight: 600; color: var(--text-main);"><%= s.name %></div>
            </td>
            <td>
                <label class="stunning-toggle" title="<%= s.stunning === 1 ? 'Stunning — click to unset' : 'Standard — click to set as stunning' %>">
                    <input
                        type="checkbox"
                        class="stunning-checkbox"
                        data-id="<%= s.id %>"
                        data-country-id="<%= s.countryId %>"
                        <%= s.stunning === 1 ? 'checked' : '' %>
                    >
                    <span class="toggle-track">
                        <span class="toggle-thumb"></span>
                    </span>
                    <span class="toggle-label"><%= s.stunning === 1 ? 'Stunning' : 'Standard' %></span>
                </label>
            </td>
            <td>
                <div class="action-btns">
                    <button class="action-btn btn-edit btn-edit-state"
                            data-id="<%= s.id %>"
                            data-name="<%= s.name %>"
                            data-country-id="<%= s.countryId %>"
                            data-stunning="<%= s.stunning %>"
                            data-image="<%= s.image %>"
                            title="Edit State">
                        <i data-lucide="edit-3"></i>
                    </button>
                    <button class="action-btn btn-delete btn-delete-state" data-id="<%= s.id %>" title="Delete State">
                        <i data-lucide="trash-2"></i>
                    </button>
                </div>
            </td>
        </tr>
    <% }) %>
<% } else { %>
    <tr>
        <td colspan="3" style="text-align: center; color: var(--text-muted); padding: 4rem;">
            <i data-lucide="map" size="48" style="opacity: 0.2; margin-bottom: 1rem;"></i>
            <p>No states found matching your criteria.</p>
        </td>
    </tr>
<% } %>

<!-- Pagination Data (Hidden) -->
<tr style="display: none;">
    <td colspan="3">
        <div id="pagination-data"
             data-current-page="<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>"
             data-total-pages="<%= typeof totalPages !== 'undefined' ? totalPages : 1 %>"
             data-total-count="<%= typeof totalCount !== 'undefined' ? totalCount : 0 %>">
        </div>
    </td>
</tr>
