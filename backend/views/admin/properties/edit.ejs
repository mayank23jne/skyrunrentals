                                                                <option value="<%=i%>" <%=property.bathroom==i
                                                                    ? 'selected' : '' %>><%=i%>
                                                                </option>
                                                                <% } %>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Property Type</label>
                                                    <div class="field-input-wrapper">
                                                        <select name="propertyType" class="form-control"
                                                            style="max-width: 400px;">
                                                            <% propertyTypes.forEach(t=> { %>
                                                                <option value="<%=t.propertyName%>"
                                                                    <%=property.propertyType===t.propertyName
                                                                    ? 'selected' : '' %>><%=t.propertyName%>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Property View</label>
                                                    <div class="field-input-wrapper">
                                                        <select name="propertyViewId" class="form-control"
                                                            style="max-width: 400px;">
                                                            <option value="">Select View</option>
                                                            <% propertyViews.forEach(v=> { %>
                                                                <option value="<%=v.id%>"
                                                                    <%=Number(property.propertyViewId)===Number(v.id)
                                                                    ? 'selected' : '' %>><%=v.name%>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>On which floor</label>
                                                    <div class="field-input-wrapper">
                                                        <input type="text" name="onWhichFloor" class="form-control"
                                                            value="<%=property.onWhichFloor%>"
                                                            style="max-width: 400px;">
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Elevator</label>
                                                    <div class="field-input-wrapper"
                                                        style="display: flex; align-items: center; min-height: 40px;">
                                                        <input type="checkbox" name="elevator" value="Yes"
                                                            <%=property.elevator==='Yes' ? 'checked' : '' %>
                                                        style="width: 18px; height: 18px;">
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Sleeps</label>
                                                    <div class="field-input-wrapper">
                                                        <select name="sleeps" class="form-control"
                                                            style="max-width: 400px;">
                                                            <% for(let i=1; i<=20; i++) { %>
                                                                <option value="<%=i%>" <%=property.sleeps==i
                                                                    ? 'selected' : '' %>><%=i%>
                                                                </option>
                                                                <% } %>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>

                                            <% if (admin.usertype === '0' || admin.usertype === '2') { %>
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Assign Property</label>
                                                    <div class="field-input-wrapper">
                                                        <select name="assignTo" class="form-control"
                                                            style="max-width: 400px;">
                                                            <option value="">Select Owner</option>
                                                            <% users.forEach(u=> { %>
                                                                <option value="<%=u.id%>" <%=property.assignTo===u.id
                                                                    ? 'selected' : '' %>>
                                                                    Customer ID - <%= u.id %> (<%= u.firstname %> <%= u.lastname %>)
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <% } else { %>
                                                <input type="hidden" name="assignTo" value="<%= property.assignTo %>">
                                            <% } %>
                                        </div>

                                        <div class="form-footer"
                                            style="justify-content: flex-start; margin-left: 140px; padding-left: 1.5rem; gap: 0.5rem; margin-top: 2rem;">
                                            <button type="button" class="btn-continue-outline"
                                                onclick="nextTab(2)">Continue ></button>
                                            <button type="submit" class="btn-continue">Save</button>
                                        </div>
                                    </div>

                                    <!-- TAB 2: Contact -->
                                    <div class="tab-content" id="tab-2">
                                        <div class="form-section-title"
                                            style="font-weight: 300; font-size: 1.5rem; color: #555; margin-bottom: 2rem;">
                                            Provide your Contact details</div>
                                        <div class="form-grid">
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Name</label>
                                                    <div class="field-input-wrapper">
                                                        <input type="text" name="contactName" class="form-control"
                                                            value="<%=property.contacts && property.contacts[0] ? property.contacts[0].name : ''%>"
                                                            style="max-width: 400px; border-radius: 4px;">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Country</label>
                                                    <div class="field-input-wrapper">
                                                        <select name="contactCountry" class="form-control"
                                                            id="contact-country-select"
                                                            style="max-width: 400px; border-radius: 4px;">
                                                            <option value="">Select Country</option>
                                                            <% countries.forEach(function(c) { %>
                                                                <option value="<%= c.id %>" data-name="<%= c.name %>"
                                                                    <%=(property && property.contacts &&
                                                                    property.contacts[0] &&
                                                                    property.contacts[0].country===c.id.toString())
                                                                    ? 'selected' : '' %>>
                                                                    <%= c.name %>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>State</label>
                                                    <div class="field-input-wrapper">
                                                        <select name="contactState" class="form-control"
                                                            id="contact-state-select"
                                                            style="max-width: 400px; border-radius: 4px;">
                                                            <option value="">Select State</option>
                                                            <% contactStates.forEach(function(s) { %>
                                                                <option value="<%= s.id %>" data-name="<%= s.name %>"
                                                                    <%=(property && property.contacts &&
                                                                    property.contacts[0] &&
                                                                    property.contacts[0].state===s.id.toString())
                                                                    ? 'selected' : '' %>>
                                                                    <%= s.name %>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>City</label>
                                                    <div class="field-input-wrapper">
                                                        <select name="contactCity" class="form-control"
                                                            id="contact-city-select"
                                                            style="max-width: 400px; border-radius: 4px;">
                                                            <option value="">Select City</option>
                                                            <% contactCities.forEach(function(c) { %>
                                                                <option value="<%= c.id %>" data-name="<%= c.name %>"
                                                                    <%=(property && property.contacts &&
                                                                    property.contacts[0] &&
                                                                    property.contacts[0].city===c.name) ? 'selected'
                                                                    : '' %>>
                                                                    <%= c.name %>
                                                                </option>
                                                                <% }) %>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Street Address</label>
                                                    <div class="field-input-wrapper">
                                                        <input type="text" name="contactStreetAddress"
                                                            class="form-control"
                                                            value="<%=property.contacts && property.contacts[0] ? property.contacts[0].streetAddress : ''%>"
                                                            style="max-width: 400px; border-radius: 4px;">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>ZIP</label>
                                                    <div class="field-input-wrapper">
                                                        <input type="text" name="contactZip" class="form-control"
                                                            value="<%=property.contacts && property.contacts[0] ? property.contacts[0].zip : ''%>"
                                                            style="max-width: 400px; border-radius: 4px;">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Email</label>
                                                    <div class="field-input-wrapper">
                                                        <input type="email" name="contactEmail" class="form-control"
                                                            value="<%=property.contacts && property.contacts[0] ? property.contacts[0].email : ''%>"
                                                            style="max-width: 400px; border-radius: 4px;">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Re-Type Email</label>
                                                    <div class="field-input-wrapper">
                                                        <input type="email" name="contactRegEmail" class="form-control"
                                                            value="<%=property.contacts && property.contacts[0] ? property.contacts[0].regEmail : ''%>"
                                                            style="max-width: 400px; border-radius: 4px;">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Mobile Number</label>
                                                    <div class="field-input-wrapper">
                                                        <input type="text" name="contactMobileNumber"
                                                            class="form-control"
                                                            value="<%=property.contacts && property.contacts[0] ? property.contacts[0].mobileNumber : ''%>"
                                                            style="max-width: 400px; border-radius: 4px;">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Calling Hours</label>
                                                    <div class="field-input-wrapper">
                                                        <input type="text" name="contactCallingHours"
                                                            class="form-control"
                                                            value="<%=property.contacts && property.contacts[0] ? property.contacts[0].callingHours : ''%>"
                                                            style="max-width: 400px; border-radius: 4px;">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="form-group full-width">
                                                <div class="field-row">
                                                    <label>Alternate Email</label>
                                                    <div class="field-input-wrapper">
                                                        <input type="email" name="contactAltEmail" class="form-control"
                                                            value="<%=property.contacts && property.contacts[0] ? property.contacts[0].altEmail : ''%>"
                                                            style="max-width: 400px; border-radius: 4px;">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-footer"
                                            style="justify-content: flex-start; margin-left: 140px; padding-left: 1.5rem; gap: 0.5rem; margin-top: 2rem;">
                                            <button type="button" class="btn-back" onclick="prevTab(1)">
                                                < Back</button>
                                                    <button type="button" class="btn-continue-outline"
                                                        onclick="nextTab(3)">Continue ></button>
                                                    <button type="submit" class="btn-continue">Save</button>
                                        </div>
                                    </div>

                                    <!-- TAB 3: Photos -->
                                    <div class="tab-content" id="tab-3">
                                        <div class="form-section-title">Property Photos</div>
                                        <div class="photo-upload-zone" id="drop-zone">
                                            <input type="file" id="photo-input" multiple accept="image/*">
                                            <div class="upload-icon-box">
                                                <i data-lucide="upload-cloud" size="32"></i>
                                            </div>
                                            <h3 style="margin-bottom: 0.5rem">Click or drag photos to upload</h3>
                                            <p style="color: var(--text-muted); font-size: 0.875rem">Upload up to 20
                                                high-quality images of your property</p>
                                        </div>

                                        <div class="photo-grid" id="photo-preview-grid">
                                            <!-- Existing photos -->
                                            <% property.photos.forEach(photo=> { %>
                                                <div class="photo-card" data-id="<%=photo.id%>">
                                                    <img src="<%=photo.imageName%>">
                                                    <% if (photo.defaultImage===1) { %>
                                                        <div class="main-badge"><i data-lucide="check" size="12"></i>
                                                            MAIN PHOTO</div>
                                                        <% } %>
                                                            <div class="photo-actions">
                                                                <button type="button"
                                                                    class="action-icon btn-main-photo <%=photo.defaultImage === 1 ? 'active' : ''%>"
                                                                    title="Set as main"
                                                                    onclick="setMainPhoto(<%= photo.id %>, this)">
                                                                    <i data-lucide="star" size="14"></i>
                                                                </button>
                                                                <button type="button"
                                                                    class="action-icon btn-remove-photo" title="Remove"
                                                                    onclick="removeExistingPhoto(<%= photo.id %>, this)">
                                                                    <i data-lucide="x" size="14"></i>
                                                                </button>
                                                            </div>
                                                </div>
                                                <% }) %>
                                        </div>

                                        <input type="hidden" name="removedPhotos" id="removedPhotosInput">
                                        <input type="hidden" name="mainPhotoId" id="mainPhotoIdInput" <% const
                                            defaultPhoto=property.photos ? property.photos.find(p=> p.defaultImage ===
                                        1) : null; %>
                                        value="<%= defaultPhoto ? defaultPhoto.id : '' %>">

                                            <div class="form-footer"
                                                style="justify-content: flex-start; margin-left: 140px; padding-left: 1.5rem; gap: 0.5rem; margin-top: 2rem;">
                                                <button type="button" class="btn-back" onclick="prevTab(2)">
                                                    < Back</button>
                                                        <button type="button" class="btn-continue-outline"
                                                            onclick="nextTab(4)">Continue ></button>
                                                        <button type="submit" class="btn-continue">Save</button>
                                            </div>
                                    </div>

                                    <!-- TAB 4: Amenities -->
                                    <div class="tab-content" id="tab-4">
                                        <% const hasAmenity=(field, value)=> {
                                            if (!property.amenities || property.amenities.length === 0) return false;
                                            const amen = property.amenities[0][field];
                                            if (!amen) return false;
                                            return typeof amen === 'string' && amen.split(', ').includes(value);
                                            };
                                            const bedding = (property.beddingInfo && property.beddingInfo[0]) ?
                                            property.beddingInfo[0] : {};
                                            const nearby = (property.nearbyPlaces && property.nearbyPlaces[0]) ?
                                            property.nearbyPlaces[0] : {};
                                            const amenity = (property.amenities && property.amenities[0]) ?
                                            property.amenities[0] : {};
                                            %>
                                            <!-- Bedding Info -->
                                            <div class="amenity-section">
                                                <div class="amenity-section-title">
                                                    Bedding Info
                                                </div>
                                                <div class="bedding-grid">
                                                    <% const bedTypes=[ { label: 'Kings' , name: 'king' }, {
                                                        label: 'Queen' , name: 'queen' }, { label: 'Double' ,
                                                        name: 'doubleBed' }, { label: 'Twin/ Single' ,
                                                        name: 'twinSingle' }, { label: 'Child Bed' , name: 'childBed' },
                                                        { label: 'Baby Crib' , name: 'babyCrib' } ]; %>
                                                        <% bedTypes.forEach(bed=> { %>
                                                            <div class="bed-input-wrapper">
                                                                <span class="bed-label">
                                                                    <%= bed.label %>
                                                                </span>
                                                                <select name="<%= bed.name %>" class="bed-count-select">
                                                                    <% for(let i=0; i<=10; i++) { %>
                                                                        <option value="<%=i%>" <%=bedding[bed.name]==i
                                                                            ? 'selected' : '' %>><%=i%>
                                                                        </option>
                                                                        <% } %>
                                                                </select>
                                                            </div>
                                                            <% }) %>

                                                                <div class="bed-input-wrapper">
                                                                    <span class="bed-label">Sleep Sofa /Futon</span>
                                                                    <select name="sleepSofaFuton"
                                                                        class="bed-count-select">
                                                                        <% for(let i=0; i<=10; i++) { %>
                                                                            <option value="<%=i%>"
                                                                                <%=bedding.sleepSofaFuton==i
                                                                                ? 'selected' : '' %>><%=i%>
                                                                            </option>
                                                                            <% } %>
                                                                    </select>
                                                                </div>

                                                                <div class="bed-input-wrapper"
                                                                    style="grid-column: span 2;">
                                                                    <span class="bed-label">Note</span>
                                                                    <input type="text" name="beddingNote"
                                                                        class="bedding-note-input"
                                                                        value="<%= bedding.note || '' %>"
                                                                        placeholder="Note">
                                                                </div>
                                                </div>
                                            </div>


                                            <div class="amenity-section">
                                                <div class="amenity-section-title">
                                                    <i data-lucide="map-pin"></i> Nearby Places & Activities
                                                </div>
                                                <div class="nearby-grid"
                                                    style="display: grid; grid-template-columns: 1fr; gap: 1rem; padding-left: 110px;">
                                                    <% const mainPlaces=[ { label: 'Nearest Airport' ,
                                                        name: 'nearestAirport' , distName: 'airportDistance' ,
                                                        unitName: 'nearestAirportUnit' }, { label: 'Nearest Beach' ,
                                                        name: 'nearestBeach' , distName: 'beachDistance' ,
                                                        unitName: 'nearestBeachUnit' }, { label: 'Nearest Ferry' ,
                                                        name: 'nearestFerry' , distName: 'ferryDistance' ,
                                                        unitName: 'nearestFerryUnit' }, { label: 'Nearest Train' ,
                                                        name: 'nearestTrain' , distName: 'trainDistance' ,
                                                        unitName: 'nearestTrainUnit' }, { label: 'Nearest Highway' ,
                                                        name: 'nearestHighway' , distName: 'highwayDistance' ,
                                                        unitName: 'nearestHighwayUnit' }, { label: 'Nearest Bar' ,
                                                        name: 'nearestBar' , distName: 'barDistance' ,
                                                        unitName: 'nearestBarUnit' }, { label: 'Nearest Ski' ,
                                                        name: 'nearestSki' , distName: 'skiDistance' ,
                                                        unitName: 'nearestSkiUnit' }, { label: 'Nearest Golf' ,
                                                        name: 'nearestGolf' , distName: 'golfDistance' ,
                                                        unitName: 'nearestGolfUnit' }, { label: 'Nearest Restaurant' ,
                                                        name: 'nearestRestaurant' , distName: 'restaurantDistance' ,
                                                        unitName: 'nearestRestaurantUnit' } ]; %>

                                                        <% mainPlaces.forEach(place=> {
                                                            const fullDist = nearby[place.distName] || '';
                                                            const distVal = fullDist.replace(/[^0-9.]/g, '');
                                                            const unitVal = fullDist.includes('km') ? 'km' : 'miles';
                                                            %>
                                                            <div class="nearby-item-row"
                                                                style="display: grid; grid-template-columns: 160px 1fr 100px 100px; gap: 1rem; align-items: center;">
                                                                <label class="nearby-label"
                                                                    style="font-size: 0.875rem; color: #64748b; font-weight: 500; text-align: right;">
                                                                    <%= place.label %>
                                                                </label>
                                                                <input type="text" name="<%= place.name %>"
                                                                    class="form-control"
                                                                    style="height: 38px; border-radius: 4px;"
                                                                    value="<%= nearby[place.name] || '' %>">
                                                                <input type="text" name="<%= place.distName %>"
                                                                    class="form-control"
                                                                    style="height: 38px; border-radius: 4px; text-align: center;"
                                                                    value="<%= distVal || '0.00' %>">
                                                                <select name="<%= place.unitName %>"
                                                                    class="form-control"
                                                                    style="height: 38px; border-radius: 4px;">
                                                                    <option value="miles" <%=unitVal==='miles'
                                                                        ? 'selected' : '' %>>miles</option>
                                                                    <option value="km" <%=unitVal==='km' ? 'selected'
                                                                        : '' %>>km</option>
                                                                </select>
                                                            </div>
                                                            <% }) %>
                                                </div>
                                            </div>

                                            <hr
                                                style="margin: 4rem 0 2rem 0; border: none; border-top: 1px solid #edf2f9;">

                                            <div class="amenity-section">
                                                <div class="amenity-section-title">
                                                    <i data-lucide="check-circle-2"></i> Suitability
                                                </div>
                                                <div class="form-grid"
                                                    style="grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 1.5rem;">
                                                    <div class="form-group row-align"
                                                        style="display:flex; align-items:center; gap:1rem; justify-content: flex-end;">
                                                        <label
                                                            style="width: 100px; text-align: right; color: #64748b; font-weight: 500;">Children</label>
                                                        <select name="childrenSuitability" class="form-control"
                                                            style="max-width: 250px;">
                                                            <option value="children welcome"
                                                                <%=amenity.childrenSuitability==='children welcome'
                                                                ? 'selected' : '' %>>children welcome</option>
                                                            <option value="not suitable"
                                                                <%=amenity.childrenSuitability==='not suitable'
                                                                ? 'selected' : '' %>>not suitable</option>
                                                        </select>
                                                    </div>
                                                    <div class="form-group row-align"
                                                        style="display:flex; align-items:center; gap:1rem; justify-content: flex-start;">
                                                        <label
                                                            style="width: 100px; text-align: right; color: #64748b; font-weight: 500;">Smoking</label>
                                                        <select name="smokingSuitability" class="form-control"
                                                            style="max-width: 250px;">
                                                            <option value="smoking allowed"
                                                                <%=amenity.smokingSuitability==='smoking allowed'
                                                                ? 'selected' : '' %>>smoking allowed</option>
                                                            <option value="non smoking only"
                                                                <%=amenity.smokingSuitability==='non smoking only'
                                                                ? 'selected' : '' %>>non smoking only</option>
                                                        </select>
                                                    </div>
                                                    <div class="form-group row-align"
                                                        style="display:flex; align-items:center; gap:1rem; justify-content: flex-end;">
                                                        <label
                                                            style="width: 100px; text-align: right; color: #64748b; font-weight: 500;">Wheel
                                                            Chairs</label>
                                                        <select name="wheelchairSuitability" class="form-control"
                                                            style="max-width: 250px;">
                                                            <option value="wheelchair inaccessible"
                                                                <%=amenity.wheelchairSuitability==='wheelchair inaccessible'
                                                                ? 'selected' : '' %>>Wheelchair inaccessible</option>
                                                            <option value="wheelchair accessible"
                                                                <%=amenity.wheelchairSuitability==='wheelchair accessible'
                                                                ? 'selected' : '' %>>Wheelchair accessible</option>
                                                        </select>
                                                    </div>
                                                    <div class="form-group row-align"
                                                        style="display:flex; align-items:center; gap:1rem; justify-content: flex-start;">
                                                        <label
                                                            style="width: 100px; text-align: right; color: #64748b; font-weight: 500;">Pets</label>
                                                        <select name="petsSuitability" class="form-control"
                                                            style="max-width: 250px;">
                                                            <option value="pets considered"
                                                                <%=amenity.petsSuitability==='pets considered'
                                                                ? 'selected' : '' %>>pets considered</option>
                                                            <option value="pets not allowed"
                                                                <%=amenity.petsSuitability==='pets not allowed'
                                                                ? 'selected' : '' %>>pets not allowed</option>
                                                        </select>
                                                    </div>
                                                </div>

                                                <div class="checkbox-grid"
                                                    style="grid-template-columns: repeat(2, 1fr); gap: 1rem; padding-left: 110px;">
                                                    <label class="checkbox-item"><input type="checkbox"
                                                            name="otherSuitability"
                                                            value="Minimum Age Limit for Renters"
                                                            <%=(amenity.otherSuitability||'').includes('Minimum Age Limit for Renters') ? 'checked' : '' %>> <span>Minimum Age
