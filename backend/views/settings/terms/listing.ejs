<!DOCTYPE html>
<html lang="en">
<%- include('../../partials/head') %>
    <!-- Include Quill stylesheet -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

    <style>
        .settings-card {
            max-width: 1000px;
            margin: 0 auto;
            background: white;
            border-radius: 1.5rem;
            padding: 2.5rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
            border: 1px solid var(--border);
        }

        .form-group {
            margin-bottom: 2rem;
        }

        .form-group label {
            display: block;
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 0.75rem;
        }

        .input-wrapper input {
            width: 100%;
            padding: 1rem 1.25rem;
            border-radius: 1rem;
            border: 1.5px solid var(--border);
            font-size: 1rem;
            color: var(--text-main);
            background: #fafbfc;
            transition: all 0.3s;
            outline: none;
        }

        .input-wrapper input:focus {
            background: white;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

        /* Quill Customization */
        #editor-container {
            height: 400px;
            border-bottom-left-radius: 1rem;
            border-bottom-right-radius: 1rem;
            border-color: var(--border);
            background: #fafbfc;
            font-size: 1rem;
        }

        .ql-toolbar.ql-snow {
            border-top-left-radius: 1rem;
            border-top-right-radius: 1rem;
            border-color: var(--border);
            background: #f8fafc;
            padding: 0.75rem;
        }

        .ql-container.ql-snow {
            border-color: var(--border);
        }

        .save-btn {
            width: 100%;
            padding: 1.25rem;
            border-radius: 1rem;
            background: var(--primary);
            color: white;
            font-size: 1rem;
            font-weight: 700;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
            margin-top: 2rem;
        }

        .save-btn:hover {
            background: #4338ca;
            transform: translateY(-2px);
        }

        .notification {
            position: fixed;
            top: 2rem;
            right: 2rem;
            padding: 1.25rem 2rem;
            border-radius: 1rem;
            background: white;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            display: flex;
            align-items: center;
            gap: 1rem;
            z-index: 1000;
            transform: translateX(120%);
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border-left: 5px solid #10b981;
        }

        .notification.active {
            transform: translateX(0);
        }
    </style>

    <body>
        <div class="layout">
            <%- include('../../partials/sidebar', { activePage: 'settings-terms' }) %>
                <main>
                    <%- include('../../partials/header', { pageTitle: 'Terms & Conditions Settings' }) %>

                        <div class="settings-card">
                            <div style="margin-bottom: 2.5rem; display: flex; align-items: center; gap: 1.5rem;">
                                <div style="width: 56px; height: 56px; background: rgba(79, 70, 229, 0.1); border-radius: 1rem; display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0;">
                                    <i data-lucide="scroll-text" size="28"></i>
                                </div>
                                <div>
                                    <h2 style="margin: 0; font-size: 1.25rem;">Global Terms & Conditions</h2>
                                    <p style="color: var(--text-muted); font-size: 0.875rem;">Manage the legal agreement visible to all platform users.</p>
                                </div>
                            </div>

                            <form id="terms-form">
                                <div class="form-group">
                                    <label for="terms-title">Section Title</label>
                                    <div class="input-wrapper">
                                        <input type="text" id="terms-title" name="title" value="<%= terms.title %>" placeholder="e.g. Platform Terms of Service" required>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label>Agreement Content</label>
                                    <div id="editor-container"><%- terms.detail %></div>
                                    <input type="hidden" id="terms-detail" name="detail">
                                </div>

                                <button type="submit" class="save-btn" id="submit-btn">
                                    <i data-lucide="save"></i>
                                    <span>Save Terms & Conditions</span>
                                </button>
                            </form>
                        </div>
                </main>
        </div>

        <div id="success-notification" class="notification">
            <div style="width: 32px; height: 32px; background: #ecfdf5; color: #10b981; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i data-lucide="check" size="18"></i>
            </div>
            <div style="font-weight: 600; color: var(--text-main);">Legal terms updated successfully!</div>
        </div>

        <!-- Include Quill library -->
        <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
                if (window.lucide) lucide.createIcons();

                // Initialize Quill Editor
                const quill = new Quill('#editor-container', {
                    modules: {
                        toolbar: [
                            [{ header: [1, 2, 3, false] }],
                            ['bold', 'italic', 'underline', 'strike'],
                            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                            ['link', 'clean']
                        ]
                    },
                    placeholder: 'Enter the full terms and conditions content here...',
                    theme: 'snow'
                });

                const form = document.getElementById('terms-form');
                const titleInput = document.getElementById('terms-title');
                const detailInput = document.getElementById('terms-detail');
                const submitBtn = document.getElementById('submit-btn');
                const notification = document.getElementById('success-notification');

                form.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    // Sync Quill content to hidden input
                    detailInput.value = quill.root.innerHTML;
                    
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<i data-lucide="loader-2" class="animate-spin"></i> Saving...';
                    if (window.lucide) lucide.createIcons();

                    const data = {
                        title: titleInput.value,
                        detail: detailInput.value
                    };

                    try {
                        const response = await fetch('/api/admin/settings/terms', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        });

                        if (response.ok) {
                            notification.classList.add('active');
                            setTimeout(() => {
                                notification.classList.remove('active');
                            }, 3000);
                        }
                    } catch (error) {
                        console.error('Update failed:', error);
                        alert('Something went wrong. Please try again.');
                    } finally {
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<i data-lucide="save"></i> Save Terms & Conditions';
                        if (window.lucide) lucide.createIcons();
                    }
                });
            });
        </script>
    </body>

</html>
