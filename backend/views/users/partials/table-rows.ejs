<table class="data-table">
    <thead>
        <tr>
            <th>User ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Contact</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <% if (users && users.length> 0) { %>
            <% users.forEach(user=> { %>
                <tr>
                    <td style="font-family: monospace; font-weight: 700; color: var(--text-main);">#<%= user.id %>
                    </td>
                    <td>
                        <div style=" font-weight: 600; color: var(--text-main);">
                            <%= user.firstname %>
                                <%= user.lastname %>
                        </div>
                    </td>
                    <td>
                        <div style="color: var(--text-muted); font-size: 0.875rem;">
                            <%= user.email %>
                        </div>
                    </td>
                    <td>
                        <%= user.contact_number %>
                    </td>
                    <td>
                        <button class="status-btn <%= user.status === 0 ? 'status-active' : 'status-inactive' %>"
                            data-id="<%= user.id %>">
                            <%= user.status===0 ? 'Active' : 'Deactivated' %>
                        </button>
                    </td>
                    <td>
                        <div class="action-btns">
                            <a href="/admin/users/<%= user.id %>/view" class="action-btn btn-view"
                                title="View Details">
                                <i data-lucide="eye"></i>
                            </a>
                            <a href="/admin/users/<%= user.id %>/edit" class="action-btn btn-edit"
                                title="Edit User">
                                <i data-lucide="edit-3"></i>
                            </a>
                            <button class="action-btn btn-delete" data-id="<%= user.id %>" title="Delete User">
                                <i data-lucide="trash-2"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 4rem;">
                                <i data-lucide="users" size="48" style="opacity: 0.2; margin-bottom: 1rem;"></i>
                                <p>No users found matching your search.</p>
                            </td>
                        </tr>
                        <% } %>
    </tbody>
</table>

<% if (typeof totalCount !=='undefined' && totalCount> 0) { %>
    <div
        style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding: 0 0.5rem; flex-wrap: wrap; gap: 1rem;">
        <div style="color: var(--text-muted); font-size: 0.875rem;">
            Showing <strong>
                <%= (currentPage - 1) * 10 + 1 %>
            </strong> to <strong>
                <%= Math.min(currentPage * 10, totalCount) %>
            </strong> of <strong>
                <%= totalCount %>
            </strong> users
        </div>

        <% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
            <div style="display: flex; align-items: center; gap: 0.375rem;">
                <a href="?page=<%= Math.max(1, currentPage - 1) %><%= searchQuery ? '&search=' + searchQuery : '' %>"
                    class="page-btn <%= currentPage === 1 ? 'disabled' : '' %>"
                    style="width: 36px; height: 36px; min-width: 36px;">
                    <i data-lucide="chevron-left" style="width: 16px; height: 16px;"></i>
                </a>

                <% for (let i=1; i <=totalPages; i++) { %>
                    <% if (i===1 || i===totalPages || (i>= currentPage - 1 && i <= currentPage + 1)) { %>
                            <a href="?page=<%= i %><%= searchQuery ? '&search=' + searchQuery : '' %>"
                                class="page-btn <%= currentPage === i ? 'active' : '' %>"
                                style="width: 36px; height: 36px; min-width: 36px;">
                                <%= i %>
                            </a>
                            <% } else if (i===currentPage - 2 || i===currentPage + 2) { %>
                                <span style="padding: 0 0.25rem; color: var(--text-muted); line-height: 36px;">…</span>
                                <% } %>
                                    <% } %>

                                        <a href="?page=<%= Math.min(totalPages, currentPage + 1) %><%= searchQuery ? '&search=' + searchQuery : '' %>"
                                            class="page-btn <%= currentPage === totalPages ? 'disabled' : '' %>"
                                            style="width: 36px; height: 36px; min-width: 36px;">
                                            <i data-lucide="chevron-right" style="width: 16px; height: 16px;"></i>
                                        </a>
            </div>
            <% } %>
    </div>
    <% } %>