<% if (currencies && currencies.length> 0) { %>
    <% currencies.forEach(c=> { %>
        <tr id="currency-<%= c.id %>">
            <td>
                <div style="font-weight: 600; color: var(--text-main);">
                    <%= c.name %>
                </div>
            </td>
            <td><code><%= c.code %></code></td>
            <td>
                <div style="font-weight: 700; color: var(--primary);">
                    <%= c.conversionRate %>
                </div>
            </td>
            <td style="color: var(--text-muted);">
                <%= c.poundConversion %>
            </td>
            <td>
                <div class="action-btns">
                    <a href="/admin/settings/currency/<%= c.id %>/edit" class="action-btn btn-edit"
                        title="Edit Currency">
                        <i data-lucide="edit-3"></i>
                    </a>
                    <button class="action-btn btn-delete btn-delete-currency" data-id="<%= c.id %>"
                        title="Delete Currency">
                        <i data-lucide="trash-2"></i>
                    </button>
                </div>
            </td>
        </tr>
        <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="5" style="text-align: center; color: var(--text-muted); padding: 4rem;">
                        <i data-lucide="banknote" size="48" style="opacity: 0.2; margin-bottom: 1rem;"></i>
                        <p>No currencies found matching your criteria.</p>
                    </td>
                </tr>
                <% } %>

                    <!-- Pagination Data (Hidden) -->
                    <tr style="display: none;">
                        <td colspan="5">
                            <div id="pagination-data"
                                data-current-page="<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>"
                                data-total-pages="<%= typeof totalPages !== 'undefined' ? totalPages : 1 %>"
                                data-total-count="<%= typeof totalCount !== 'undefined' ? totalCount : 0 %>">
                            </div>
                        </td>
                    </tr>