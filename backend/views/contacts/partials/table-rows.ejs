<% if (contacts && contacts.length > 0) { %>
    <% contacts.forEach(contact => { %>
        <tr>
            <td>
                <div style="font-weight: 600; color: var(--text-main);"><%= contact.firstname %> <%= contact.lastname %></div>
            </td>
            <td>
                <div style="font-size: 0.9rem; color: var(--text-main); word-break: break-word;"><%= contact.email %></div>
            </td>
            <td>
                <div style="font-size: 0.8125rem; color: var(--text-muted); word-break: break-word;"><%= contact.website || 'N/A' %></div>
            </td>
            <td>
                <div style="font-size: 0.8125rem; color: var(--text-muted); word-break: break-word; white-space: normal; line-height: 1.5;">
                    <%= contact.message %>
                </div>
            </td>
            <td>
                <div class="action-btns">
                    <button class="action-btn btn-view" data-message="<%= contact.message %>" onclick="viewMessage(this.getAttribute('data-message'))" title="View Message">
                        <i data-lucide="eye"></i>
                    </button>
                    <button class="action-btn btn-delete" onclick="deleteContact(<%= contact.id %>)" title="Delete Contact">
                        <i data-lucide="trash-2"></i>
                    </button>
                </div>
            </td>
        </tr>
    <% }) %>
    <tr style="display: none;" id="pagination-data"
        data-current-page="<%= currentPage %>"
        data-total-pages="<%= totalPages %>"
        data-total-count="<%= totalCount %>">
    </tr>
<% } else { %>
    <tr>
        <td colspan="5" style="text-align: center; padding: 3rem; color: var(--text-muted);">
            <div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
                <i data-lucide="user-x" style="width: 32px; height: 32px; opacity: 0.5;"></i>
                <p style="margin: 0;">No contacts found matching your search.</p>
            </div>
        </td>
    </tr>
    <tr style="display: none;" id="pagination-data"
        data-current-page="1"
        data-total-pages="1"
        data-total-count="0">
    </tr>
<% } %>

