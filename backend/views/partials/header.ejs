<header>
    <% 
        const adminObj = (typeof admin !== 'undefined' && admin) ? admin : {};
        const displayName = adminObj.firstname || adminObj.username || adminObj.email || 'Admin'; 
    %>
    <div style="display: flex; align-items: center; gap: 1rem; width: 100%;">
        <button id="mobile-menu-btn" style="display: none; background: none; border: none; cursor: pointer; color: var(--text-main);">
            <i data-lucide="menu" style="width: 28px; height: 28px;"></i>
        </button>
        <div style="flex: 1;">
            <h1><%= pageTitle %></h1>
            <p class="subtitle">Welcome back, <%= displayName %></p>
        </div>
        <div class="user-profile">
            <div class="avatar"><%= displayName.charAt(0).toUpperCase() %></div>
            <div style="text-align: right; display: none;" class="desktop-only-user-info">
                <p style="font-weight: 700"><%= displayName %></p>
                <p style="font-size: 0.875rem; color: var(--text-muted)">System Admin</p>
            </div>
        </div>
    </div>
    <style>
        @media (max-width: 1024px) {
            #mobile-menu-btn { display: block !important; }
            .desktop-only-user-info { display: none !important; }
            header h1 { font-size: 1.5rem; }
        }
        @media (min-width: 1025px) {
            .desktop-only-user-info { display: block !important; }
        }
    </style>
</header>
<div class="sidebar-overlay" id="sidebar-overlay"></div>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const menuBtn = document.getElementById('mobile-menu-btn');
        const overlay = document.getElementById('sidebar-overlay');
        const body = document.body;
        
        function toggleSidebar() {
            body.classList.toggle('sidebar-open');
            overlay.classList.toggle('active');
        }

        if (menuBtn && overlay) {
            menuBtn.addEventListener('click', toggleSidebar);
            overlay.addEventListener('click', toggleSidebar);
        }
    });
</script>

<!-- Global Delete Modal -->
<div id="global-delete-modal" class="modal-overlay" style="display: none;">
    <div class="modal-window">
        <div class="modal-icon warning">
            <i data-lucide="alert-triangle"></i>
        </div>
        <h3 id="global-delete-title" class="modal-title">Confirm Deletion</h3>
        <p id="global-delete-message" class="modal-message">Are you sure you want to delete this item? This action cannot be undone.</p>
        <div class="modal-actions">
            <button class="btn-secondary" onclick="closeGlobalDeleteModal()">Cancel</button>
            <button class="btn-danger" id="global-delete-confirm-btn">Delete</button>
        </div>
    </div>
</div>

<style>
    .modal-overlay {
        position: fixed; inset: 0; background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px); z-index: 1000;
        display: flex; align-items: center; justify-content: center;
    }
    .modal-window {
        background: #ffffff; border-radius: 1.5rem; padding: 2rem;
        width: 90%; max-width: 400px; text-align: center;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        transform: scale(0.95); animation: modalPop 0.2s ease forwards;
    }
    @keyframes modalPop { to { transform: scale(1); } }
    .modal-icon {
        width: 64px; height: 64px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.5rem;
    }
    .modal-icon.warning { background: #fee2e2; color: #ef4444; }
    .modal-icon.warning i { width: 32px; height: 32px; }
    .modal-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; }
    .modal-message { color: var(--text-muted); line-height: 1.5; margin-bottom: 2rem; }
    .modal-actions { display: flex; gap: 1rem; justify-content: center; }
    .btn-secondary {
        background: #f1f5f9; color: var(--text-main);
        padding: 0.75rem 1.5rem; border-radius: 0.75rem; border: none; font-weight: 600; cursor: pointer;
    }
    .btn-danger {
        background: #ef4444; color: white;
        padding: 0.75rem 1.5rem; border-radius: 0.75rem; border: none; font-weight: 600; cursor: pointer;
    }
</style>

<script>
    let globalDeleteResolve = null;

    function openDeleteModal(title = 'Confirm Deletion', message = 'Are you sure you want to delete this item? This action cannot be undone.') {
        return new Promise((resolve) => {
            document.getElementById('global-delete-title').innerText = title;
            document.getElementById('global-delete-message').innerText = message;
            document.getElementById('global-delete-modal').style.display = 'flex';
            if (window.lucide) lucide.createIcons();
            
            globalDeleteResolve = resolve;
        });
    }

    function closeGlobalDeleteModal() {
        document.getElementById('global-delete-modal').style.display = 'none';
        if (globalDeleteResolve) {
            globalDeleteResolve(false);
            globalDeleteResolve = null;
        }
    }

    document.getElementById('global-delete-confirm-btn').addEventListener('click', () => {
        document.getElementById('global-delete-modal').style.display = 'none';
        if (globalDeleteResolve) {
            globalDeleteResolve(true);
            globalDeleteResolve = null;
        }
    });
</script>

<!-- Global View Modal -->
<div id="global-view-modal" class="modal-overlay" style="display: none;">
    <div class="modal-window" style="max-width: 500px; text-align: left;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3 id="global-view-title" class="modal-title" style="margin: 0; font-size: 1.25rem;">View Details</h3>
            <button onclick="closeGlobalViewModal()" style="background: none; border: none; cursor: pointer; color: var(--text-muted); padding: 0.25rem;">
                <i data-lucide="x" style="width: 20px; height: 20px;"></i>
            </button>
        </div>
        <div id="global-view-content" style="color: var(--text-main); line-height: 1.6; margin-bottom: 2rem; max-height: 60vh; overflow-y: auto; background: #f8f9fc; padding: 1rem; border-radius: 0.5rem; border: 1px solid var(--border); white-space: pre-wrap;"></div>
        <div class="modal-actions" style="justify-content: flex-end;">
            <button class="btn-secondary" onclick="closeGlobalViewModal()">Close</button>
        </div>
    </div>
</div>

<script>
    function openViewModal(title, content) {
        document.getElementById('global-view-title').innerText = title;
        document.getElementById('global-view-content').innerText = content;
        document.getElementById('global-view-modal').style.display = 'flex';
        if (window.lucide) lucide.createIcons();
    }

    function closeGlobalViewModal() {
        document.getElementById('global-view-modal').style.display = 'none';
    }
</script>
