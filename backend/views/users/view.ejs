<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
    <div class="layout">
        <%- include('../partials/sidebar', { activePage: 'users' }) %>
        <main>
            <%- include('../partials/header', { pageTitle: 'User Details' }) %>
            <div style="margin-bottom: 2rem;">
                <a href="/admin/users" class="action-btn" style="width: auto; padding: 0 1.5rem; height: 40px; border-radius: 1rem; display: inline-flex; align-items: center; gap: 0.5rem; background: white; border: 1px solid var(--border); color: var(--text-main); text-decoration: none; font-weight: 500;">
                    <i data-lucide="arrow-left" style="width: 18px; height: 18px;"></i> Back to Users
                </a>
            </div>

            <style>
                .detail-card { background: white; border-radius: 2rem; border: 1px solid var(--border); overflow: hidden; }
                .detail-header { padding: 3rem; background: linear-gradient(135deg, var(--primary), var(--primary-light)); color: white; display: flex; align-items: center; gap: 2rem; }
                .detail-avatar { width: 120px; height: 120px; background: rgba(255, 255, 255, 0.2); backdrop-filter: blur(10px); color: white; border-radius: 3rem; display: flex; align-items: center; justify-content: center; font-size: 3rem; font-weight: 700; border: 2px solid rgba(255, 255, 255, 0.3); }
                .detail-basic h2 { font-size: 2rem; margin-bottom: 0.5rem; }
                .detail-basic p { opacity: 0.8; font-size: 1.1rem; }
                
                .detail-body { padding: 3rem; display: grid; grid-template-columns: repeat(2, 1fr); gap: 3rem; }
                .detail-section h3 { font-size: 1.25rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.75rem; color: var(--text-main); }
                .detail-row { display: flex; justify-content: space-between; padding: 1rem 0; border-bottom: 1px solid #f1f5f9; }
                .detail-row:last-child { border-bottom: none; }
                .detail-label { color: var(--text-muted); font-weight: 500; }
                .detail-value { font-weight: 600; color: var(--text-main); }
                
                .status-tag { padding: 0.5rem 1rem; border-radius: 2rem; font-size: 0.875rem; font-weight: 700; }
            </style>

            <div class="detail-card">
                <div class="detail-header">
                    <div class="detail-avatar"><%= user.firstname.charAt(0) %></div>
                    <div class="detail-basic">
                        <h2><%= user.firstname %> <%= user.lastname %></h2>
                        <p><%= user.email %></p>
                        <div style="margin-top: 1rem;">
                            <span class="status-tag <%= user.status === 0 ? 'status-active' : 'status-inactive' %>" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3);">
                                <%= user.status === 0 ? 'Active User' : 'Deactivated' %>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="detail-body">
                    <div class="detail-section">
                        <h3><i data-lucide="info"></i> Personal Information</h3>
                        <div class="detail-row"><span class="detail-label">First Name</span><span class="detail-value"><%= user.firstname %></span></div>
                        <div class="detail-row"><span class="detail-label">Last Name</span><span class="detail-value"><%= user.lastname %></span></div>
                        <div class="detail-row"><span class="detail-label">Email</span><span class="detail-value"><%= user.email %></span></div>
                        <div class="detail-row"><span class="detail-label">Contact</span><span class="detail-value"><%= user.contact_number %></span></div>
                    </div>

                    <div class="detail-section">
                        <h3><i data-lucide="map-pin"></i> Location Details</h3>
                        <div class="detail-row"><span class="detail-label">Address</span><span class="detail-value"><%= user.address %></span></div>
                        <div class="detail-row"><span class="detail-label">City</span><span class="detail-value"><%= user.city %></span></div>
                        <div class="detail-row"><span class="detail-label">State</span><span class="detail-value"><%= user.state %></span></div>
                        <div class="detail-row"><span class="detail-label">Zip Code</span><span class="detail-value"><%= user.zipcode %></span></div>
                    </div>

                    <div class="detail-section">
                        <h3><i data-lucide="settings"></i> System Details</h3>
                        <div class="detail-row"><span class="detail-label">User Type</span><span class="detail-value"><%= user.usertype === '0' ? 'Admin' : 'General User' %></span></div>
                        <div class="detail-row"><span class="detail-label">Joined Date</span><span class="detail-value"><%= new Date(user.create_date).toLocaleDateString() %></span></div>
                    </div>
                </div>
            </div>
            <div class="card" style="margin-top: 2rem;">
                <div class="controls-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; gap: 1rem; flex-wrap: wrap;">
                    <div style="flex: 1;">
                        <h3 style="margin: 0; font-size: 1.5rem; color: var(--primary);"><%= user.firstname %> <%= user.lastname %> Properties</h3>
                    </div>
                    <div style="display: flex; gap: 1rem; align-items: center;">
                        <a href="/admin/properties/add?userId=<%= user.id %>" class="btn-primary" style="text-decoration: none;">Add Property</a>
                    </div>
                </div>

                <div class="controls-row" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; gap: 1rem; flex-wrap: wrap;">
                    <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.875rem;">
                        <select id="records-per-page" class="form-control" style="width: auto; padding: 0.4rem 2rem 0.4rem 0.8rem;">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        records
                    </div>
                    <div class="search-box">
                        <i data-lucide="search"></i>
                        <input type="text" id="table-search" placeholder="Search..." value="">
                    </div>
                </div>

                <style>
                    .data-table { width: 100%; border-collapse: separate; border-spacing: 0; margin-bottom: 2rem; }
                    .data-table th { text-align: left; padding: 1.25rem 1.5rem; color: var(--text-muted); font-weight: 600; font-size: 0.875rem; border-bottom: 1px solid var(--border); background-color: #fafbfc; }
                    .data-table td { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border); font-size: 0.9375rem; vertical-align: middle; }
                    .search-box { position: relative; display: flex; align-items: center; }
                    .search-box i { position: absolute; left: 1.25rem; width: 18px; height: 18px; color: var(--text-muted); pointer-events: none; }
                    .search-box input { padding: 0.6rem 1.25rem 0.6rem 2.5rem; border-radius: 0.5rem; border: 1.5px solid var(--border); background: white; font-size: 0.9375rem; outline: none; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); color: var(--text-main); }
                    .search-box input:focus { border-color: var(--primary); }
                    .property-thumb { width: 64px; height: 64px; border-radius: 0.5rem; object-fit: cover; }
                    .pagination-footer { margin-top: 2rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
                    .pagination-info { font-size: 0.875rem; color: var(--text-muted); font-weight: 500; }
                    .pagination-controls { display: flex; gap: 0.5rem; }
                    .page-btn { min-width: 40px; height: 40px; border-radius: 0.75rem; border: 1.5px solid var(--border); background: white; color: var(--text-main); font-size: 0.875rem; font-weight: 600; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; }
                    .page-btn:hover:not(:disabled) { border-color: var(--primary); color: var(--primary); background-color: #f8f9ff; }
                    .page-btn.active { background: var(--primary); border-color: var(--primary); color: white; }
                    .page-btn:disabled { opacity: 0.5; cursor: not-allowed; }
                </style>

                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Photo</th>
                                <th>Title</th>
                                <th>Property Type</th>
                                <th style="text-align: right;">Action</th>
                            </tr>
                        </thead>
                        <tbody id="properties-table-body">
                            <%- include('partials/property-table-rows') %>
                        </tbody>
                    </table>
                </div>

                <div class="pagination-footer">
                    <div class="pagination-info">
                        Showing <span id="start-count">0</span> to <span id="end-count">0</span> of <span id="total-count"><%= totalCount %></span> entries
                    </div>
                    <div class="pagination-controls" id="pagination-controls"></div>
                </div>
            </div>
        </main>
    </div>
    
    <script>
        window.currentPage = <%= currentPage %>;

        async function updateTable(page = 1, search = '') {
            const tbody = document.getElementById('properties-table-body');
            const response = await fetch(`/api/admin/users/<%= user.id %>/view?page=${page}&ajax=true`);
            const html = await response.text();
            tbody.innerHTML = html;

            const paginationData = document.getElementById('pagination-data');
            if (paginationData) {
                window.currentPage = parseInt(paginationData.dataset.currentPage);
                renderPagination(window.currentPage, parseInt(paginationData.dataset.totalPages));
                updateInfo(window.currentPage, parseInt(paginationData.dataset.totalCount));
            }
            if (window.lucide) lucide.createIcons();
        }

        function renderPagination(current, total) {
            const controls = document.getElementById('pagination-controls');
            if (!controls) return;
            let html = `<button class="page-btn" ${current === 1 ? 'disabled' : ''} onclick="updateTable(${current - 1}, '')">Previous</button>`;
            for (let i = 1; i <= total; i++) {
                if (i === 1 || i === total || (i >= current - 1 && i <= current + 1)) {
                    html += `<button class="page-btn ${i === current ? 'active' : ''}" onclick="updateTable(${i}, '')">${i}</button>`;
                } else if (i === current - 2 || i === current + 2) {
                    html += `<span style="padding: 0.5rem">...</span>`;
                }
            }
            html += `<button class="page-btn" ${current === total || total === 0 ? 'disabled' : ''} onclick="updateTable(${current + 1}, '')">Next</button>`;
            controls.innerHTML = html;
        }

        function updateInfo(current, total) {
            const pageSize = 10;
            const start = total === 0 ? 0 : (current - 1) * pageSize + 1;
            const end = Math.min(current * pageSize, total);
            document.getElementById('start-count').textContent = start;
            document.getElementById('end-count').textContent = end;
            document.getElementById('total-count').textContent = total;
        }

        async function deleteProperty(id) {
            if (!await openDeleteModal('Delete Property', 'Are you sure you want to delete this property?')) {
                return;
            }
            
            try {
                const response = await fetch(`/api/admin/properties/${id}/delete`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                if (response.ok) {
                    window.location.reload();
                } else {
                    alert('Failed to delete property');
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            if (window.lucide) lucide.createIcons();
            const totalPages = parseInt('<%= typeof totalPages !== "undefined" ? totalPages : 1 %>');
            const totalCount = parseInt('<%= typeof totalCount !== "undefined" ? totalCount : 0 %>');
            renderPagination(window.currentPage, totalPages);
            updateInfo(window.currentPage, totalCount);
        });
    </script>
</body>
</html>
