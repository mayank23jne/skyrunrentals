<header>
    <% 
        const adminObj = (typeof admin !== 'undefined' && admin) ? admin : {};
        const displayName = adminObj.firstname || adminObj.username || adminObj.email || 'Admin'; 
    %>
    <div style="display: flex; align-items: center; gap: 1rem; width: 100%;">
        <button id="mobile-menu-btn" style="display: none; background: none; border: none; cursor: pointer; color: var(--text-main);">
            <i data-lucide="menu" style="width: 28px; height: 28px;"></i>
        </button>
        <div style="flex: 1;">
            <h1><%= pageTitle %></h1>
            <p class="subtitle">Welcome back, <%= displayName %></p>
        </div>
        <div class="user-profile">
            <div class="avatar"><%= displayName.charAt(0).toUpperCase() %></div>
            <div style="text-align: right; display: none;" class="desktop-only-user-info">
                <p style="font-weight: 700"><%= displayName %></p>
                <p style="font-size: 0.875rem; color: var(--text-muted)">System Admin</p>
            </div>
        </div>
    </div>
    <style>
        @media (max-width: 1024px) {
            #mobile-menu-btn { display: block !important; }
            .desktop-only-user-info { display: none !important; }
            header h1 { font-size: 1.5rem; }
        }
        @media (min-width: 1025px) {
            .desktop-only-user-info { display: block !important; }
        }
    </style>
</header>
<div class="sidebar-overlay" id="sidebar-overlay"></div>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const menuBtn = document.getElementById('mobile-menu-btn');
        const overlay = document.getElementById('sidebar-overlay');
        const body = document.body;
        
        function toggleSidebar() {
            body.classList.toggle('sidebar-open');
            overlay.classList.toggle('active');
        }

        if (menuBtn && overlay) {
            menuBtn.addEventListener('click', toggleSidebar);
            overlay.addEventListener('click', toggleSidebar);
        }
    });
</script>
