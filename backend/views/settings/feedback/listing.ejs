<!DOCTYPE html>
<html lang="en">
<%- include('../../partials/head') %>
    <!-- Include Quill stylesheet -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

    <style>
        .data-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-bottom: 2rem;
        }

        .data-table th {
            text-align: left;
            padding: 1.25rem 1.5rem;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.875rem;
            border-bottom: 1px solid var(--border);
            background-color: #fafbfc;
        }

        .data-table td {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border);
            font-size: 0.9375rem;
            vertical-align: middle;
        }

        .action-btns {
            display: flex;
            gap: 0.75rem;
        }

        .action-btn {
            width: 32px;
            height: 32px;
            border-radius: 0.5rem;
            border: 1px solid var(--border);
            background: white;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
            cursor: pointer;
            text-decoration: none;
            padding: 0;
        }

        .btn-edit:hover {
            color: #f59e0b;
            border-color: #f59e0b;
            background-color: #fffbeb;
        }

        .btn-delete:hover {
            color: #ef4444;
            border-color: #ef4444;
            background-color: #fef2f2;
        }

        /* Modal Styles */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            padding: 1rem;
        }

        .modal-content {
            background: white;
            border-radius: 1.5rem;
            width: 100%;
            max-width: 600px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.2);
            overflow: hidden;
            animation: modalIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @keyframes modalIn {
            from {
                opacity: 0;
                transform: translateY(24px) scale(0.97);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .modal-header {
            padding: 1.5rem 2rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: linear-gradient(135deg, #f8f9ff 0%, #ffffff 100%);
        }

        .modal-header h3 {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-main);
            margin: 0;
        }

        .modal-close-btn {
            background: #f1f5f9;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }

        .modal-close-btn:hover {
            background: #fee2e2;
            color: #ef4444;
        }

        .modal-body {
            padding: 1.75rem 2rem;
            max-height: 70vh;
            overflow-y: auto;
        }

        .modal-footer {
            padding: 1.25rem 2rem;
            background: #fafbfc;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 0.75rem;
        }

        .form-group {
            margin-bottom: 1.25rem;
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        .form-group label {
            font-size: 0.8125rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .form-group input,
        .form-group select {
            padding: 0.75rem 1rem;
            border-radius: 0.75rem;
            border: 1.5px solid var(--border);
            background: white;
            outline: none;
            transition: all 0.2s;
            font-size: 0.9375rem;
            width: 100%;
            box-sizing: border-box;
        }

        .form-group input:focus,
        .form-group select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.08);
        }

        /* Star Rating */
        .star-rating {
            display: flex;
            gap: 0.5rem;
        }

        .star-rating i {
            cursor: pointer;
            color: #cbd5e1;
            transition: scale 0.2s;
        }

        .star-rating i:hover {
            scale: 1.2;
        }

        .star-rating i.active {
            color: #f59e0b;
            fill: #f59e0b;
        }

        /* Image Upload Zone */
        .upload-zone {
            border: 2px dashed var(--border);
            border-radius: 1rem;
            padding: 1.5rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            background: #fafbfc;
            position: relative;
            overflow: hidden;
        }

        .upload-zone:hover,
        .upload-zone.drag-over {
            border-color: var(--primary);
            background: #f0f0ff;
        }

        .upload-zone input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
            width: 100%;
            height: 100%;
        }

        .upload-zone-icon {
            width: 40px;
            height: 40px;
            background: #ede9fe;
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 0.75rem;
            color: var(--primary);
        }

        .upload-zone p {
            font-size: 0.875rem;
            color: var(--text-muted);
            margin: 0;
        }

        .upload-zone p strong {
            color: var(--primary);
        }

        .upload-zone small {
            font-size: 0.75rem;
            color: #94a3b8;
        }

        /* Image Preview */
        #user-image-preview {
            margin-top: 0.75rem;
            display: none;
            position: relative;
        }

        #user-image-preview img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 1rem;
            border: 1.5px solid var(--border);
            display: block;
        }

        #user-image-preview .remove-img {
            position: absolute;
            top: -10px;
            left: 85px;
            background: rgba(239, 68, 68, 0.9);
            color: white;
            border: none;
            border-radius: 50%;
            width: 26px;
            height: 26px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
        }

        /* Search and Pagination Design */
        .search-box {
            position: relative;
            display: flex;
            align-items: center;
        }

        .search-box i {
            position: absolute;
            left: 1.25rem;
            width: 18px;
            height: 18px;
            color: var(--text-muted);
            pointer-events: none;
            transition: color 0.2s;
        }

        .search-box input {
            padding: 0.875rem 1.25rem 0.875rem 3.25rem;
            border-radius: 1rem;
            border: 1.5px solid var(--border);
            background: white;
            min-width: 350px;
            font-size: 0.9375rem;
            outline: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            color: var(--text-main);
        }

        .search-box input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1), 0 10px 15px -3px rgba(0, 0, 0, 0.05);
            width: 400px;
        }

        .search-box input:focus + i {
            color: var(--primary);
        }

        .pagination-footer {
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .pagination-info {
            font-size: 0.875rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .pagination-info span {
            color: var(--text-main);
            font-weight: 600;
        }

        .pagination-controls {
            display: flex;
            gap: 0.5rem;
        }

        .page-btn {
            min-width: 40px;
            height: 40px;
            padding: 0 0.75rem;
            border-radius: 0.75rem;
            border: 1.5px solid var(--border);
            background: white;
            color: var(--text-main);
            font-size: 0.875rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
        }

        .page-btn:hover:not(:disabled) {
            border-color: var(--primary);
            color: var(--primary);
            background-color: #f8f9ff;
            transform: translateY(-2px);
        }

        .page-btn.active {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.2);
        }

        .page-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            background: #f8f9fa;
        }

        /* Quill Editor Height */
        #editor-container {
            height: 150px;
            border-radius: 0.75rem;
            border: 1.5px solid var(--border);
            overflow: hidden;
        }

        .ql-toolbar.ql-snow {
            border-top-left-radius: 0.75rem;
            border-top-right-radius: 0.75rem;
            border-color: var(--border);
        }

        .ql-container.ql-snow {
            border-bottom-left-radius: 0.75rem;
            border-bottom-right-radius: 0.75rem;
            border-color: var(--border);
        }
    </style>

    <body>
        <div class="layout">
            <%- include('../../partials/sidebar', { activePage: 'settings-feedback' }) %>
                <main>
                    <%- include('../../partials/header', { pageTitle: 'Feedback Management' }) %>

                        <div class="card">
                            <div class="controls-row"
                                style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; gap: 1rem; flex-wrap: wrap;">
                                <div style="flex: 1; min-width: 250px;">
                                    <h3 style="margin: 0">Feedback Management</h3>
                                    <p style="color: var(--text-muted); font-size: 0.875rem">Manage user feedback and
                                        ratings</p>
                                </div>

                                <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                                    <div class="search-box">
                                        <i data-lucide="search"></i>
                                        <input type="text" id="table-search" placeholder="Search feedback..."
                                            value="<%= searchQuery %>">
                                    </div>
                                    <button onclick="openFeedbackModal()" class="btn-primary"
                                        style="display: flex; align-items: center; gap: 0.5rem; white-space: nowrap;">
                                        <i data-lucide="plus"></i> Add Feedback
                                    </button>
                                </div>
                            </div>

                            <div class="table-container">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>User</th>
                                            <th>Client & Rating</th>
                                            <th>Full Feedback</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody id="feedback-table-body">
                                        <%- include('partials/table-rows') %>
                                    </tbody>
                                </table>
                            </div>

                            <div class="pagination-footer">
                                <div class="pagination-info">
                                    Showing <span id="start-count">0</span> to <span id="end-count">0</span> of <span
                                        id="total-count">
                                        <%= totalCount %>
                                    </span> entries
                                </div>
                                <div class="pagination-controls" id="pagination-controls"></div>
                            </div>
                        </div>
                </main>
        </div>

        <!-- Modal remains the same but with specific IDs -->
        <div class="modal-overlay" id="feedback-modal" onclick="if(event.target===this) this.style.display='none'">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h3 id="modal-title">Add New Feedback</h3>
                        <p style="font-size:0.8rem; color:var(--text-muted); margin:0.2rem 0 0;">Fill in the details
                            below to save feedback</p>
                    </div>
                    <button class="modal-close-btn"
                        onclick="document.getElementById('feedback-modal').style.display='none'">
                        <i data-lucide="x" style="width:16px;height:16px;"></i>
                    </button>
                </div>
                <form id="feedback-form" enctype="multipart/form-data">
                    <input type="hidden" id="feedback-id" name="id">
                    <input type="hidden" id="field-rating" name="rating" value="5">
                    <div class="modal-body">
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                            <div class="form-group">
                                <label>User Name</label>
                                <input type="text" name="name" id="field-name" placeholder="e.g. John Doe" required>
                            </div>
                            <div class="form-group">
                                <label>Rating</label>
                                <div class="star-rating" id="star-selector">
                                    <i data-lucide="star" data-value="1" class="active"></i>
                                    <i data-lucide="star" data-value="2" class="active"></i>
                                    <i data-lucide="star" data-value="3" class="active"></i>
                                    <i data-lucide="star" data-value="4" class="active"></i>
                                    <i data-lucide="star" data-value="5" class="active"></i>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Feedback Message</label>
                            <div id="editor-container"></div>
                            <textarea name="feedbackMessage" id="field-feedbackMessage" style="display:none"></textarea>
                        </div>
                        <div class="form-group">
                            <label>User Image</label>
                            <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
                                <div class="upload-zone" id="user-upload-zone" style="flex: 1;">
                                    <input type="file" name="userImage" id="field-userImage" accept="image/*">
                                    <div class="upload-zone-icon"><i data-lucide="image"></i></div>
                                    <p><strong>Upload photo</strong></p>
                                </div>
                                <div id="user-image-preview">
                                    <img src="" alt="Preview">
                                    <button type="button" class="remove-img"
                                        onclick="window.removeFeedbackImage()">✕</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" onclick="document.getElementById('feedback-modal').style.display='none'"
                            style="cursor:pointer;padding:0.6rem 1rem; border-radius:0.75rem; border:1px solid var(--border); background:white;">Cancel</button>
                        <button type="submit" class="btn-primary" id="submit-btn">Save Feedback</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Hidden data for JS -->
        <div id="ejs-data" data-current-page="<%= currentPage %>" data-total-pages="<%= totalPages %>"
            data-total-count="<%= totalCount %>">
        </div>

        <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
        <script>
            // Global variables and functions attached to window for maximum reliability
            window.quill = null;
            window.currentPage = 1;

            window.updateStars = function (val) {
                const stars = document.querySelectorAll('#star-selector > *');
                const ratingNum = parseFloat(val);
                
                stars.forEach((s, idx) => {
                    const sVal = idx + 1;
                    // Reset
                    s.setAttribute('data-lucide', 'star');
                    s.setAttribute('fill', 'none');
                    s.style.color = '#cbd5e1';

                    if (sVal <= ratingNum) {
                        // Full Star
                        s.setAttribute('fill', '#f59e0b');
                        s.style.color = '#f59e0b';
                    } else if (sVal - 0.5 <= ratingNum) {
                        // Half Star
                        s.setAttribute('data-lucide', 'star-half');
                        s.setAttribute('fill', '#f59e0b');
                        s.style.color = '#f59e0b';
                    }
                });
                if (window.lucide) lucide.createIcons();
            };

            window.showNotification = function(message, type = 'success') {
                const toast = document.createElement('div');
                toast.style.cssText = `
                    position: fixed; top: 1.5rem; right: 1.5rem; padding: 1rem 1.5rem; 
                    background: ${type === 'success' ? '#10b981' : '#ef4444'}; color: white;
                    border-radius: 0.75rem; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
                    z-index: 9999; 
                `;
                toast.textContent = message;
                document.body.appendChild(toast);
                setTimeout(() => {
                    toast.style.opacity = '0';
                    toast.style.transition = 'opacity 0.5s';
                    setTimeout(() => toast.remove(), 500);
                }, 3000);
            };

            window.openFeedbackModal = function (data = null) {
                console.log('Opening Feedback Modal', data);
                const modal = document.getElementById('feedback-modal');
                const form = document.getElementById('feedback-form');
                const idField = document.getElementById('feedback-id');
                const nameField = document.getElementById('field-name');
                const ratingInput = document.getElementById('field-rating');

                modal.style.display = 'flex';

                if (data) {
                    document.getElementById('modal-title').textContent = 'Edit Feedback';
                    idField.value = data.id;
                    nameField.value = data.name;
                    ratingInput.value = data.rating;
                    window.updateStars(parseInt(data.rating));
                    if (window.quill) window.quill.root.innerHTML = data.feedbackMessage || '';

                    if (data.image) {
                        document.getElementById('user-image-preview').style.display = 'block';
                        document.getElementById('user-image-preview').querySelector('img').src = data.image;
                        document.getElementById('user-upload-zone').style.display = 'none';
                    }
                } else {
                    document.getElementById('modal-title').textContent = 'Add New Feedback';
                    form.reset();
                    idField.value = '';
                    ratingInput.value = '5';
                    window.updateStars(5);
                    if (window.quill) window.quill.root.innerHTML = '';
                    document.getElementById('user-image-preview').style.display = 'none';
                    document.getElementById('user-upload-zone').style.display = 'block';
                }
            };

            window.removeFeedbackImage = function () {
                document.getElementById('user-image-preview').style.display = 'none';
                document.getElementById('user-upload-zone').style.display = 'block';
                document.getElementById('field-userImage').value = '';
            };

            async function updateTable(page = 1, search = '') {
                const tbody = document.getElementById('feedback-table-body');
                const response = await fetch(`/api/admin/settings/feedback?page=${page}&search=${search}&ajax=true`);
                const html = await response.text();
                tbody.innerHTML = html;

                const paginationData = document.getElementById('pagination-data');
                if (paginationData) {
                    window.currentPage = parseInt(paginationData.dataset.currentPage);
                    renderPagination(window.currentPage, parseInt(paginationData.dataset.totalPages));
                    updateInfo(window.currentPage, parseInt(paginationData.dataset.totalCount));
                }
                if (window.lucide) lucide.createIcons();
            }

            function renderPagination(current, total) {
                const controls = document.getElementById('pagination-controls');
                if (!controls) return;
                let html = `<button class="page-btn" ${current === 1 ? 'disabled' : ''} onclick="updateTable(${current - 1}, document.getElementById('table-search').value)">Previous</button>`;
                for (let i = 1; i <= total; i++) {
                    if (i === 1 || i === total || (i >= current - 1 && i <= current + 1)) {
                        html += `<button class="page-btn ${i === current ? 'active' : ''}" onclick="updateTable(${i}, document.getElementById('table-search').value)">${i}</button>`;
                    } else if (i === current - 2 || i === current + 2) {
                        html += `<span style="padding: 0.5rem">...</span>`;
                    }
                }
                html += `<button class="page-btn" ${current === total || total === 0 ? 'disabled' : ''} onclick="updateTable(${current + 1}, document.getElementById('table-search').value)">Next</button>`;
                controls.innerHTML = html;
            }

            function updateInfo(current, total) {
                const pageSize = 10;
                const start = total === 0 ? 0 : (current - 1) * pageSize + 1;
                const end = Math.min(current * pageSize, total);
                document.getElementById('start-count').textContent = start;
                document.getElementById('end-count').textContent = end;
                document.getElementById('total-count').textContent = total;
            }

            // Initialize on DOM Load
            document.addEventListener('DOMContentLoaded', () => {
                console.log('Feedback App Initializing...');
                if (window.lucide) lucide.createIcons();

                // Quill
                if (window.Quill) {
                    window.quill = new Quill('#editor-container', {
                        theme: 'snow',
                        modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'list': 'ordered' }, { 'list': 'bullet' }], ['clean']] }
                    });
                }

                // Star Rating binding (Resilient to Lucide SVG replacement and supports half-stars)
                document.getElementById('star-selector').addEventListener('click', (e) => {
                    const star = e.target.closest('#star-selector > svg, #star-selector > i');
                    if (star) {
                        const rect = star.getBoundingClientRect();
                        const x = e.clientX - rect.left;
                        const isHalf = x < rect.width / 2;
                        
                        const stars = Array.from(document.getElementById('star-selector').children);
                        const baseVal = stars.indexOf(star) + 1;
                        const finalVal = isHalf ? baseVal - 0.5 : baseVal;
                        
                        document.getElementById('field-rating').value = finalVal;
                        window.updateStars(finalVal);
                    }
                });

                // Form Submit
                document.getElementById('feedback-form').onsubmit = async (e) => {
                    e.preventDefault();
                    if (window.quill) document.getElementById('field-feedbackMessage').value = window.quill.root.innerHTML;

                    const id = document.getElementById('feedback-id').value;
                    const url = id ? `/api/admin/settings/feedback/${id}/update` : '/api/admin/settings/feedback';
                    const formData = new FormData(e.target);

                    try {
                        const res = await fetch(url, { method: 'POST', body: formData });
                        if (res.ok) {
                            window.showNotification(id ? 'Feedback updated successfully!' : 'Feedback created successfully!');
                            document.getElementById('feedback-modal').style.display = 'none';
                            updateTable(window.currentPage, document.getElementById('table-search').value);
                        } else {
                            window.showNotification('Error saving feedback', 'error');
                        }
                    } catch (err) { 
                        console.error(err);
                        window.showNotification('Network error occurred', 'error');
                    }
                };

                // Search
                let timeout;
                document.getElementById('table-search').addEventListener('input', (e) => {
                    clearTimeout(timeout);
                    timeout = setTimeout(() => updateTable(1, e.target.value), 400);
                });

                // Initial pagination display
                const dataEl = document.getElementById('ejs-data');
                if (dataEl) {
                    renderPagination(parseInt(dataEl.dataset.currentPage), parseInt(dataEl.dataset.totalPages));
                    updateInfo(parseInt(dataEl.dataset.currentPage), parseInt(dataEl.dataset.totalCount));
                }
            });

            // Table Action Delegation
            document.getElementById('feedback-table-body').addEventListener('click', (e) => {
                const editBtn = e.target.closest('.btn-edit-feedback');
                if (editBtn) {
                    window.openFeedbackModal({
                        id: editBtn.dataset.id,
                        name: editBtn.dataset.name,
                        rating: editBtn.dataset.rating,
                        image: editBtn.dataset.image,
                        feedbackMessage: editBtn.querySelector('.full-message')?.innerHTML || ''
                    });
                }
                const deleteBtn = e.target.closest('.btn-delete-feedback');
                if (deleteBtn) {
                    if (confirm('Delete this feedback?')) {
                        fetch(`/api/admin/settings/feedback/${deleteBtn.dataset.id}/delete`, { method: 'POST' })
                            .then(res => { if (res.ok) updateTable(window.currentPage, document.getElementById('table-search').value); });
                    }
                }
            });
        </script>
    </body>

</html>