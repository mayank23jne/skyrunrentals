<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
    <div class="layout">
        <%- include('../partials/sidebar', { activePage: 'settings-currency' }) %>
        <main>
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
                <a href="/admin/settings/currency" class="action-btn" style="width: 40px; height: 40px; border-radius: 1rem; display: flex; align-items: center; justify-content: center; background: white; border: 1px solid var(--border); color: var(--text-main); text-decoration: none;">
                    <i data-lucide="arrow-left"></i>
                </a>
                <%- include('../partials/header', { pageTitle: 'Edit Currency' }) %>
            </div>

            <div class="card" style="max-width: 800px; margin: 0 auto;">
                <form id="edit-currency-form">
                    <style>
                        .form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
                        .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
                        .form-group.full-width { grid-column: span 2; }
                        label { font-size: 0.875rem; font-weight: 600; color: var(--text-muted); }
                        input, select { padding: 0.75rem 1rem; border-radius: 0.75rem; border: 1px solid var(--border); background-color: var(--bg-main); transition: all 0.2s ease; font-size: 1rem; }
                        input:focus, select:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }
                    </style>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>Currency Name</label>
                            <input type="text" name="name" value="<%= currency.name %>" required>
                        </div>
                        <div class="form-group">
                            <label>ISO Code</label>
                            <input type="text" name="code" value="<%= currency.code %>" required>
                        </div>
                        <div class="form-group">
                            <label>Conversion Rate</label>
                            <input type="number" step="0.0001" name="conversionRate" value="<%= currency.conversionRate %>" required>
                        </div>
                        <div class="form-group">
                            <label>Currency Symbol</label>
                            <input type="text" name="currency" value="<%= currency.currency %>" required>
                        </div>
                        <div class="form-group">
                            <label>Pound Conversion Description</label>
                            <input type="text" name="poundConversion" value="<%= currency.poundConversion %>">
                        </div>
                        <div class="form-group">
                            <label>Currency Code (Internal)</label>
                            <input type="number" name="currencyCode" value="<%= currency.currencyCode %>">
                        </div>

                        <div class="form-group full-width" style="margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 2rem;">
                            <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                                <a href="/admin/settings/currency" class="btn-primary" style="background: white; border: 1px solid var(--border); color: var(--text-main); text-decoration: none; display: flex; align-items: center;">Cancel</a>
                                <button type="submit" class="btn-primary">Update Currency</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>
    <script>
        document.getElementById('edit-currency-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            const response = await fetch('/api/admin/settings/currency/<%= currency.id %>/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                window.location.href = '/admin/settings/currency';
            }
        });
        lucide.createIcons();
    </script>
</body>
</html>
