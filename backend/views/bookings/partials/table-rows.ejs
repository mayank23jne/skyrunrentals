<% if (bookings && bookings.length > 0) { %>
    <% bookings.forEach(booking => { %>
        <tr>
            <td style="font-weight: 600; color: var(--text-main);">#<%= booking.propertyId %></td>
            <td><%= booking.propertyOwner || 'N/A' %></td>
            <td>
                <div style="font-weight: 500; color: var(--text-main);">
                    <%= booking.firstName %> <%= booking.lastName %>
                </div>
                <div style="font-size: 0.8125rem; color: var(--text-muted);">
                    <%= booking.email %>
                </div>
            </td>
            <td>
                <div style="color: var(--text-main);">
                    <%= new Date(booking.createdAt).toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                </div>
                <div style="font-size: 0.8125rem; color: var(--text-muted);">
                    <%= new Date(booking.createdAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                </div>
            </td>
            <td>
                <a href="/admin/bookings/<%= booking.id %>/view" class="btn-view" title="View Details">
                    <i data-lucide="eye" style="width: 18px; height: 18px;"></i>
                </a>
            </td>
        </tr>
    <% }) %>
    <tr style="display: none;" id="pagination-data" 
        data-current-page="<%= currentPage %>"
        data-total-pages="<%= totalPages %>" 
        data-total-count="<%= totalCount %>">
    </tr>
<% } else { %>
    <tr>
        <td colspan="5" style="text-align: center; padding: 3rem; color: var(--text-muted);">
            <div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
                <i data-lucide="package-open" style="width: 32px; height: 32px; opacity: 0.5;"></i>
                <p style="margin: 0;">No bookings found matching your search.</p>
            </div>
            <tr style="display: none;" id="pagination-data" 
                data-current-page="1" 
                data-total-pages="1"
                data-total-count="0">
            </tr>
        </td>
    </tr>
<% } %>
