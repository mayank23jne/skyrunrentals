<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
    <div class="layout">
        <%- include('../partials/sidebar', { activePage: 'users' }) %>
        <main>
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
                <a href="/admin/users" class="action-btn" style="width: 40px; height: 40px; border-radius: 1rem; display: flex; align-items: center; justify-content: center; background: white; border: 1px solid var(--border); color: var(--text-main); text-decoration: none;">
                    <i data-lucide="arrow-left"></i>
                </a>
                <%- include('../partials/header', { pageTitle: 'Edit User' }) %>
            </div>

            <div class="card" style="max-width: 800px; margin: 0 auto;">
                <form id="edit-user-form">
                    <style>
                        .form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
                        .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
                        .form-group.full-width { grid-column: span 2; }
                        label { font-size: 0.875rem; font-weight: 600; color: var(--text-muted); }
                        input, select { padding: 0.75rem 1rem; border-radius: 0.75rem; border: 1px solid var(--border); background-color: var(--bg-main); transition: all 0.2s ease; font-size: 1rem; }
                        input:focus, select:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1); }
                        .alert { padding: 1rem; border-radius: 0.75rem; margin-bottom: 1.5rem; display: none; }
                        .alert-success { background-color: #ecfdf5; color: #065f46; border: 1px solid #a7f3d0; }
                    </style>

                    <div id="alert" class="alert alert-success">User updated successfully!</div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label>First Name</label>
                            <input type="text" name="firstname" value="<%= user.firstname %>" required>
                        </div>
                        <div class="form-group">
                            <label>Last Name</label>
                            <input type="text" name="lastname" value="<%= user.lastname %>" required>
                        </div>
                        <div class="form-group">
                            <label>Email Address</label>
                            <input type="email" name="email" value="<%= user.email %>" required>
                        </div>
                        <div class="form-group">
                            <label>Contact Number</label>
                            <input type="text" name="contact_number" value="<%= user.contact_number %>" required>
                        </div>
                        <div class="form-group full-width">
                            <label>Address</label>
                            <input type="text" name="address" value="<%= user.address %>">
                        </div>
                        <div class="form-group">
                            <label>City</label>
                            <input type="text" name="city" value="<%= user.city %>">
                        </div>
                        <div class="form-group">
                            <label>State</label>
                            <input type="text" name="state" value="<%= user.state %>">
                        </div>
                        <div class="form-group">
                            <label>Zip Code</label>
                            <input type="number" name="zipcode" value="<%= user.zipcode %>">
                        </div>
                        <div class="form-group">
                            <label>Status</label>
                            <select name="status">
                                <option value="0" <%= user.status === 0 ? 'selected' : '' %>>Active</option>
                                <option value="1" <%= user.status === 1 ? 'selected' : '' %>>Deactivated</option>
                            </select>
                        </div>
                        <div class="form-group full-width" style="margin-top: 2rem;">
                            <div style="display: flex; gap: 1rem;">
                                <button type="submit" class="btn-primary">Update User</button>
                                <a href="/admin/users" class="btn-primary" style="background: white; border: 1px solid var(--border); color: var(--text-main); text-decoration: none; display: flex; align-items: center;">Cancel</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </main>
    </div>
    <script>
        document.getElementById('edit-user-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            data.zipcode = parseInt(data.zipcode, 10);
            data.status = parseInt(data.status, 10);

            try {
                const response = await fetch('/api/admin/users/<%= user.id %>/update', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    const alert = document.getElementById('alert');
                    alert.style.display = 'block';
                    setTimeout(() => { window.location.href = '/admin/users'; }, 1500);
                }
            } catch (err) {
                console.error(err);
            }
        });
        lucide.createIcons();
    </script>
</body>
</html>
