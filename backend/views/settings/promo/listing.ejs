<!DOCTYPE html>
<html lang="en">
<%- include('../../partials/head') %>

    <style>
        .settings-card {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 1.5rem;
            padding: 2.5rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
            border: 1px solid var(--border);
        }

        .form-group {
            margin-bottom: 2rem;
        }

        .form-group label {
            display: block;
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 0.75rem;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-wrapper i {
            position: absolute;
            left: 1.25rem;
            width: 18px;
            height: 18px;
            color: var(--text-muted);
            pointer-events: none;
            transition: color 0.3s;
        }

        .input-wrapper input {
            width: 100%;
            padding: 1rem 1.25rem 1rem 3.25rem;
            border-radius: 1rem;
            border: 1.5px solid var(--border);
            font-size: 1rem;
            color: var(--text-main);
            background: #fafbfc;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            outline: none;
        }

        .input-wrapper input:focus {
            background: white;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

        .input-wrapper input:focus + i {
            color: var(--primary);
        }

        .save-btn {
            width: 100%;
            padding: 1.25rem;
            border-radius: 1rem;
            background: var(--primary);
            color: white;
            font-size: 1rem;
            font-weight: 700;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            transition: all 0.3s;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
        }

        .save-btn:hover {
            background: #4338ca;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(79, 70, 229, 0.3);
        }

        .save-btn:active {
            transform: translateY(0);
        }

        .save-btn:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }

        .notification {
            position: fixed;
            top: 2rem;
            right: 2rem;
            padding: 1.25rem 2rem;
            border-radius: 1rem;
            background: white;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            display: flex;
            align-items: center;
            gap: 1rem;
            z-index: 1000;
            transform: translateX(120%);
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            border-left: 5px solid #10b981;
        }

        .notification.active {
            transform: translateX(0);
        }

        .promo-preview {
            margin-top: 3rem;
            padding: 2rem;
            background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
            border-radius: 1.5rem;
            border: 1px dashed var(--border);
            text-align: center;
        }

        .promo-tag {
            display: inline-block;
            background: white;
            padding: 0.75rem 1.5rem;
            border-radius: 1rem;
            border: 2px dashed var(--primary);
            color: var(--primary);
            font-family: 'Monaco', 'Consolas', monospace;
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: 2px;
            margin-top: 1rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .promo-tag:hover {
            transform: scale(1.05);
            background: #fdfdfd;
        }
    </style>

    <body>
        <div class="layout">
            <%- include('../../partials/sidebar', { activePage: 'settings-promo' }) %>
                <main>
                    <%- include('../../partials/header', { pageTitle: 'Site Promotion Settings' }) %>

                        <div class="settings-card">
                            <div style="margin-bottom: 2.5rem; text-align: center;">
                                <div style="width: 64px; height: 64px; background: rgba(79, 70, 229, 0.1); border-radius: 1.25rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: var(--primary);">
                                    <i data-lucide="ticket-percent" size="32"></i>
                                </div>
                                <h2 style="margin: 0; font-size: 1.5rem;">Global Promotion</h2>
                                <p style="color: var(--text-muted); margin-top: 0.5rem;">Update the site-wide promotional offer visible to all visitors.</p>
                            </div>

                            <form id="promo-form">
                                <div class="form-group">
                                    <label for="promo-title">Promotion Title</label>
                                    <div class="input-wrapper">
                                        <input type="text" id="promo-title" name="title" value="<%= promo.title %>" placeholder="e.g. Summer Holiday Sale 2026" required>
                                        <i data-lucide="type"></i>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="promo-code">Promo Code</label>
                                    <div class="input-wrapper">
                                        <input type="text" id="promo-code" name="code" value="<%= promo.code %>" placeholder="e.g. SUMMER25" required style="text-transform: uppercase;">
                                        <i data-lucide="hash"></i>
                                    </div>
                                </div>

                                <button type="submit" class="save-btn" id="submit-btn">
                                    <i data-lucide="save"></i>
                                    <span>Update Promotion</span>
                                </button>
                            </form>

                            <div class="promo-preview">
                                <span style="font-size: 0.875rem; color: var(--text-muted); font-weight: 500; display: block; margin-bottom: 0.5rem;">Live Preview</span>
                                <h3 id="preview-title" style="margin: 0; font-size: 1.125rem;"><%= promo.title || 'Untitled Campaign' %></h3>
                                <div class="promo-tag" id="preview-code"><%= promo.code || 'CODE777' %></div>
                            </div>
                        </div>
                </main>
        </div>

        <div id="success-notification" class="notification">
            <div style="width: 32px; height: 32px; background: #ecfdf5; color: #10b981; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <i data-lucide="check" size="18"></i>
            </div>
            <div style="font-weight: 600; color: var(--text-main);">Promotion updated successfully!</div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
                if (window.lucide) lucide.createIcons();

                const form = document.getElementById('promo-form');
                const titleInput = document.getElementById('promo-title');
                const codeInput = document.getElementById('promo-code');
                const previewTitle = document.getElementById('preview-title');
                const previewCode = document.getElementById('preview-code');
                const submitBtn = document.getElementById('submit-btn');
                const notification = document.getElementById('success-notification');

                // Live Preview logic
                titleInput.addEventListener('input', (e) => {
                    previewTitle.textContent = e.target.value || 'Untitled Campaign';
                });

                codeInput.addEventListener('input', (e) => {
                    const val = e.target.value.toUpperCase();
                    e.target.value = val;
                    previewCode.textContent = val || 'CODE777';
                });

                // Form submission
                form.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<i data-lucide="loader-2" class="animate-spin"></i> Saving...';
                    if (window.lucide) lucide.createIcons();

                    const data = {
                        title: titleInput.value,
                        code: codeInput.value
                    };

                    try {
                        const response = await fetch('/api/admin/settings/promo', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        });

                        if (response.ok) {
                            notification.classList.add('active');
                            setTimeout(() => {
                                notification.classList.remove('active');
                            }, 3000);
                        }
                    } catch (error) {
                        console.error('Update failed:', error);
                        alert('Something went wrong. Please try again.');
                    } finally {
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<i data-lucide="save"></i> Update Promotion';
                        if (window.lucide) lucide.createIcons();
                    }
                });
            });
        </script>
    </body>

</html>
