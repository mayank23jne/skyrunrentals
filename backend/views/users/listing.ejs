<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>

    <body>
        <div class="layout">
            <%- include('../partials/sidebar', { activePage: 'users' }) %>
                <main>
                    <%- include('../partials/header', { pageTitle: 'Users Listing' }) %>

                        <div class="card">
                            <div class="controls-row">
                                <style>
                                    .controls-row {
                                        display: flex;
                                        justify-content: flex-end;
                                        align-items: center;
                                        margin-bottom: 2.5rem;
                                        gap: 1rem;
                                    }

                                    .search-box {
                                        position: relative;
                                        width: 350px;
                                    }

                                    .search-box i {
                                        position: absolute;
                                        left: 1rem;
                                        top: 50%;
                                        transform: translateY(-50%);
                                        color: var(--text-muted);
                                        pointer-events: none;
                                    }

                                    .search-box input {
                                        width: 100%;
                                        padding: 0.875rem 1rem 0.875rem 3rem;
                                        border-radius: 1rem;
                                        border: 1px solid var(--border);
                                        background-color: var(--bg-main);
                                        transition: all 0.2s ease;
                                        font-size: 0.875rem;
                                    }

                                    .search-box input:focus {
                                        outline: none;
                                        border-color: var(--primary);
                                        box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
                                        width: 300px;
                                    }

                                    .data-table {
                                        width: 100%;
                                        border-collapse: separate;
                                        border-spacing: 0;
                                        margin-bottom: 2rem;
                                    }

                                    .data-table th {
                                        text-align: left;
                                        padding: 1.25rem 1.5rem;
                                        color: var(--text-muted);
                                        font-weight: 600;
                                        font-size: 0.875rem;
                                        border-bottom: 1px solid var(--border);
                                        background-color: #fafbfc;
                                    }

                                    .data-table th:first-child {
                                        border-top-left-radius: 1rem;
                                    }

                                    .data-table th:last-child {
                                        border-top-right-radius: 1rem;
                                    }

                                    .data-table td {
                                        padding: 1.25rem 1.5rem;
                                        border-bottom: 1px solid var(--border);
                                        font-size: 0.9375rem;
                                        vertical-align: middle;
                                    }

                                    .data-table tr:last-child td {
                                        border-bottom: none;
                                    }

                                    .data-table tr:hover td {
                                        background-color: rgba(79, 70, 229, 0.02);
                                    }

                                    .status-btn {
                                        border: none;
                                        padding: 0.4rem 0.8rem;
                                        border-radius: 2rem;
                                        font-size: 0.75rem;
                                        font-weight: 700;
                                        text-transform: uppercase;
                                        letter-spacing: 0.05em;
                                        cursor: pointer;
                                        transition: all 0.2s ease;
                                    }

                                    .status-active {
                                        background-color: #ecfdf5;
                                        color: #065f46;
                                    }

                                    .status-active:hover {
                                        background-color: #d1fae5;
                                    }

                                    .status-inactive {
                                        background-color: #fef2f2;
                                        color: #991b1b;
                                    }

                                    .status-inactive:hover {
                                        background-color: #fee2e2;
                                    }

                                    .action-btns {
                                        display: flex;
                                        gap: 0.75rem;
                                    }

                                    .action-btn {
                                        width: 32px;
                                        height: 32px;
                                        border-radius: 0.5rem;
                                        border: 1px solid var(--border);
                                        background: white;
                                        color: var(--text-muted);
                                        display: flex;
                                        align-items: center;
                                        justify-content: center;
                                        transition: all 0.2s ease;
                                        cursor: pointer;
                                        text-decoration: none;
                                    }

                                    .btn-view:hover {
                                        color: var(--primary);
                                        border-color: var(--primary);
                                        background-color: rgba(79, 70, 229, 0.05);
                                    }

                                    .btn-edit:hover {
                                        color: #f59e0b;
                                        border-color: #f59e0b;
                                        background-color: #fffbeb;
                                    }

                                    .btn-delete:hover {
                                        color: #ef4444;
                                        border-color: #ef4444;
                                        background-color: #fef2f2;
                                    }

                                    .pagination {
                                        display: flex;
                                        align-items: center;
                                        justify-content: center;
                                        gap: 0.5rem;
                                        margin-top: 1rem;
                                    }

                                    .page-btn {
                                        min-width: 40px;
                                        height: 40px;
                                        display: flex;
                                        align-items: center;
                                        justify-content: center;
                                        border-radius: 0.75rem;
                                        border: 1px solid var(--border);
                                        background: white;
                                        color: var(--text-main);
                                        text-decoration: none;
                                        font-weight: 600;
                                        transition: all 0.2s ease;
                                    }

                                    .page-btn:hover:not(.disabled) {
                                        border-color: var(--primary);
                                        color: var(--primary);
                                    }

                                    .page-btn.active {
                                        background-color: var(--primary);
                                        border-color: var(--primary);
                                        color: white;
                                    }

                                    .page-btn.disabled {
                                        opacity: 0.4;
                                        cursor: not-allowed;
                                    }
                                </style>
                                <div class="search-box">
                                    <input type="text" id="userSearch" placeholder="search.."
                                        value="<%= searchQuery %>">
                                </div>
                            </div>

                            <div id="table-container">
                                <%- include('./partials/table-rows', { users, totalPages, currentPage, searchQuery }) %>
                            </div>
                        </div>
                </main>
        </div>
        <script>
            // Real-time search with debounce
            let searchTimeout;
            const searchInput = document.getElementById('userSearch');
            const tableContainer = document.getElementById('table-container');

            searchInput.addEventListener('input', function (e) {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(async () => {
                    const search = e.target.value.trim();
                    const response = await fetch(`/api/admin/users?search=${encodeURIComponent(search)}&ajax=true`);
                    const html = await response.text();
                    tableContainer.innerHTML = html;
                    lucide.createIcons();
                    // Update URL without reload
                    const newUrl = window.location.pathname + (search ? `?search=${encodeURIComponent(search)}` : '');
                    window.history.pushState({ path: newUrl }, '', newUrl);
                }, 300);
            });

            // Event delegation for actions
            tableContainer.addEventListener('click', async (e) => {
                const statusBtn = e.target.closest('.status-btn');
                if (statusBtn) {
                    const currentStatus = statusBtn.textContent.trim();
                    const actionName = currentStatus === 'Active' ? 'deactivate' : 'activate';
                    
                    const confirmed = await openDeleteModal(
                        'Change Status', 
                        `Are you sure you want to ${actionName} this user?`,
                        'Confirm'
                    );

                    if (confirmed) {
                        const userId = statusBtn.dataset.id;
                        const response = await fetch(`/api/admin/users/${userId}/toggle-status`, { method: 'POST' });
                        if (response.ok) {
                            const user = await response.json();
                            statusBtn.className = `status-btn ${user.status === 0 ? 'status-active' : 'status-inactive'}`;
                            statusBtn.textContent = user.status === 0 ? 'Active' : 'Deactivated';
                        }
                    }
                }

                const deleteBtn = e.target.closest('.btn-delete');
                if (deleteBtn) {
                    const confirmed = await openDeleteModal('Delete User', 'Are you sure you want to delete this user?');
                    if (confirmed) {
                        const userId = deleteBtn.dataset.id;
                        const response = await fetch(`/api/admin/users/${userId}/delete`, { method: 'POST' });
                        if (response.ok) {
                            deleteBtn.closest('tr').remove();
                        }
                    }
                }
            });

            lucide.createIcons();
        </script>
    </body>

</html>
