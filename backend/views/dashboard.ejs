<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>

    <body>
        <div class="layout">
            <%- include('partials/sidebar', { activePage: 'dashboard' }) %>
                <main>
                    <%- include('partials/header', { pageTitle: 'Dashboard' }) %>

                        <!-- Stats Grid -->
                        <div class="stats-grid">
                            <style>
                                .stats-grid {
                                    display: grid;
                                    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
                                    gap: 2rem;
                                    margin-bottom: 3rem;
                                }

                                .stat-card {
                                    background-color: var(--white);
                                    padding: 2rem;
                                    border-radius: 2rem;
                                    border: 1px solid var(--border);
                                    box-shadow: 0 4px 20px -10px rgba(0, 0, 0, 0.05);
                                }

                                .stat-icon {
                                    width: 48px;
                                    height: 48px;
                                    border-radius: 1rem;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    margin-bottom: 1.5rem;
                                }

                                .stat-label {
                                    color: var(--text-muted);
                                    font-size: 0.875rem;
                                    font-weight: 600;
                                    text-transform: uppercase;
                                    letter-spacing: 0.05em;
                                }

                                .stat-value {
                                    font-size: 1.75rem;
                                    font-weight: 700;
                                    margin-top: 0.5rem;
                                }

                                .stat-trend {
                                    font-size: 0.75rem;
                                    font-weight: 700;
                                    display: flex;
                                    align-items: center;
                                    gap: 0.25rem;
                                    margin-top: 0.75rem;
                                }

                                .trend-up {
                                    color: #10b981;
                                }

                                @media (max-width: 1200px) {
                                    .stats-grid {
                                        grid-template-columns: repeat(2, 1fr);
                                        gap: 1.5rem;
                                    }
                                }

                                @media (max-width: 768px) {
                                    .stats-grid {
                                        grid-template-columns: 1fr;
                                        gap: 1rem;
                                        margin-bottom: 2rem;
                                    }

                                    .stat-card {
                                        padding: 1.5rem;
                                        border-radius: 1.5rem;
                                    }
                                }
                            </style>
                            <% if (admin && admin.usertype==='0' ) { %>
                                <div class="stat-card" onclick="window.location.href='/admin/users'"
                                    style="cursor: pointer;">
                                    <div class="stat-icon" style="background-color: #f5f3ff; color: #8b5cf6"><i
                                            data-lucide="users"></i></div>
                                    <p class="stat-label">Total Users</p>
                                    <h2 class="stat-value">
                                        <%= stats.totalUsers %>
                                    </h2>
                                </div>
                                <% } %>
                                    <div class="stat-card" onclick="window.location.href='/admin/properties'"
                                        style="cursor: pointer;">
                                        <div class="stat-icon" style="background-color: #eff6ff; color: #3b82f6"><i
                                                data-lucide="home"></i></div>
                                        <p class="stat-label">Total Properties</p>
                                        <h2 class="stat-value">
                                            <%= stats.totalProperties %>
                                        </h2>
                                    </div>
                                    <div class="stat-card">
                                        <div class="stat-icon" style="background-color: #fffaf0; color: #f59e0b"><i
                                                data-lucide="mail"></i></div>
                                        <p class="stat-label">Booking Enquiries</p>
                                        <h2 class="stat-value">
                                            <%= stats.totalEnquiries %>
                                        </h2>
                                    </div>
                                    <% if (admin && admin.usertype==='0' ) { %>
                                        <div class="stat-card">
                                            <div class="stat-icon" style="background-color: #ecfdf5; color: #10b981"><i
                                                    data-lucide="calendar-check"></i></div>
                                            <p class="stat-label">Active Bookings</p>
                                            <h2 class="stat-value">
                                                <%= stats.totalBookings %>
                                            </h2>
                                        </div>
                                        <% } %>
                        </div>

                        <!-- Content Grid -->
                        <div class="content-grid">
                            <style>
                                .content-grid {
                                    display: grid;
                                    grid-template-columns: 2fr 1fr;
                                    gap: 2rem;
                                }

                                .activity-list {
                                    display: flex;
                                    flex-direction: column;
                                    gap: 1rem;
                                }

                                .activity-item {
                                    display: flex;
                                    align-items: center;
                                    justify-content: space-between;
                                    padding: 1.25rem;
                                    border-radius: 1.5rem;
                                    background-color: var(--bg-main);
                                    transition: transform 0.2s ease;
                                }

                                .activity-item:hover {
                                    transform: scale(1.01);
                                }

                                .activity-info {
                                    display: flex;
                                    align-items: center;
                                    gap: 1rem;
                                }

                                .activity-dot {
                                    width: 10px;
                                    height: 10px;
                                    border-radius: 50%;
                                    background-color: var(--accent);
                                }

                                .activity-title {
                                    font-weight: 600;
                                }

                                .activity-time {
                                    color: var(--text-muted);
                                    font-size: 0.875rem;
                                }

                                .promo-card {
                                    background-color: var(--primary);
                                    color: var(--white);
                                    padding: 2.5rem;
                                    border-radius: 2.5rem;
                                    position: relative;
                                    overflow: hidden;
                                }

                                .promo-card h3 {
                                    color: var(--accent);
                                    margin-bottom: 1rem;
                                }

                                .promo-card p {
                                    opacity: 0.8;
                                    margin-bottom: 2rem;
                                    line-height: 1.6;
                                }

                                .bg-pattern {
                                    position: absolute;
                                    bottom: -20px;
                                    right: -20px;
                                    opacity: 0.1;
                                    transform: rotate(-15deg);
                                }

                                @media (max-width: 1024px) {
                                    .content-grid {
                                        grid-template-columns: 1fr;
                                        gap: 1.5rem;
                                    }

                                    .promo-card {
                                        padding: 2rem;
                                        border-radius: 1.5rem;
                                    }
                                }
                            </style>
                            <div class="card">
                                <h3 style="margin-bottom: 2rem">Recent Activity</h3>
                                <div class="activity-list">
                                    <% if (recentActivity && recentActivity.length> 0) { %>
                                        <% recentActivity.forEach(activity=> { %>
                                            <div class="activity-item">
                                                <div class="activity-info">
                                                    <div class="activity-dot"></div>
                                                    <div>
                                                        <p class="activity-title">
                                                            <%= activity.action %>
                                                        </p>
                                                        <p class="activity-time">
                                                            <%= activity.time %>
                                                        </p>
                                                    </div>
                                                </div>
                                                <i data-lucide="more-horizontal"
                                                    style="color: var(--text-muted); cursor: pointer"></i>
                                            </div>
                                            <% }) %>
                                                <% } else { %>
                                                    <div class="activity-item"
                                                        style="justify-content: center; padding: 2rem;">
                                                        <p style="color: var(--text-muted); font-weight: 500;">There is
                                                            no recent activity</p>
                                                    </div>
                                                    <% } %>
                                </div>
                            </div>
                            <% if (admin && admin.usertype==='1' ) { %>
                                <div class="promo-card">
                                    <h3>Go Premium</h3>
                                    <p>Unlock advanced analytics, property comparisons, and batch marketing tools.</p>
                                    <button class="btn-primary"
                                        style="background-color: var(--accent); color: var(--primary)"
                                        onclick="window.location.href='<%= process.env.APP_URL || 'http://localhost:5173' %>/list-property?scrollToPlans=true'">Upgrade
                                        Now</button>
                                    <i data-lucide="crown" class="bg-pattern" size="120"></i>
                                </div>
                                <% } %>
                        </div>
                </main>
        </div>
        <script>lucide.createIcons();</script>
    </body>

</html>