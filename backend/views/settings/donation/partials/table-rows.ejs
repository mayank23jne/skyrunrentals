<% if (donations && donations.length > 0) { %>
    <% donations.forEach(d => { %>
        <tr id="donation-<%= d.id %>">
            <td>
                <div style="font-weight: 600; color: var(--text-main);">
                    <%= d.name %> <%= d.middleName %> <%= d.lastName %>
                </div>
            </td>
            <td>
                <div style="font-size: 0.875rem; color: var(--text-muted);"><%= d.email %></div>
            </td>
            <td>
                <div style="font-size: 0.875rem; color: var(--text-muted);"><%= d.phone %></div>
            </td>
            <td>
                <div style="font-weight: 700; color: var(--primary);">
                    $<%= parseFloat(d.amount).toLocaleString(undefined, { minimumFractionDigits: 2 }) %>
                </div>
            </td>
            <td>
                <div style="font-size: 0.875rem; color: var(--text-muted);">
                    <%= d.streetAddress %> <%= d.addressLine2 ? ', ' + d.addressLine2 : '' %>
                </div>
            </td>
            <td>
                <div class="action-btns">
                    <button class="action-btn" title="View Details" onclick="viewDonationDetails(<%= d.id %>)">
                        <i data-lucide="eye"></i>
                    </button>
                </div>
            </td>
        </tr>
    <% }) %>
<% } else { %>
    <tr>
        <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 4rem;">
            <i data-lucide="hand-heart" size="48" style="opacity: 0.2; margin-bottom: 1rem;"></i>
            <p>No donation records found.</p>
        </td>
    </tr>
<% } %>

<!-- Pagination Data (Hidden) -->
<tr style="display: none;">
    <td colspan="6">
        <div id="pagination-data"
             data-current-page="<%= currentPage %>"
             data-total-pages="<%= totalPages %>"
             data-total-count="<%= totalCount %>">
        </div>
    </td>
</tr>
